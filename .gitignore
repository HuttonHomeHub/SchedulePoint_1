# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------------------------------------------------------
# Build output / caches
# ---------------------------------------------------------------------------
dist/
build/
out/
coverage/
.turbo/
.next/
*.tsbuildinfo
.vite/
.cache/
.eslintcache
.stylelintcache

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
playwright-report/
playwright-report-edit/
playwright/.cache/
test-results/
blob-report/

# ---------------------------------------------------------------------------
# Environment & secrets — never commit real secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ---------------------------------------------------------------------------
# Generated (NestJS @nestjs/swagger CLI plugin metadata)
# ---------------------------------------------------------------------------
apps/api/src/metadata.ts

# ---------------------------------------------------------------------------
# Prisma
# ---------------------------------------------------------------------------
prisma/*.db
prisma/*.db-journal

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
