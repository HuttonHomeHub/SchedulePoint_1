{
  "name": "@repo/web",
  "version": "0.1.0",
  "private": true,
  "description": "Blank App web client — React + Vite + Tailwind CSS + shadcn/ui.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
