// Prisma schema for the Blank App API.
// Docs: https://www.prisma.io/docs
//
// Conventions: see docs/DATABASE.md. Columns are snake_case in the database
// (via @map/@@map) while Prisma fields stay camelCase. Timestamps are
// timestamptz (UTC). Primary keys are UUID v7 (time-ordered). Every table
// carries created_at/updated_at; mutable rows carry a soft-delete (deleted_at)
// and an optimistic-locking version.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity (Better Auth) — ADR-0003, ADR-0016.
//
// These four tables are owned by Better Auth (the authentication provider) and
// must keep the field names it expects; @map keeps the DB columns snake_case
// and the tables plural per docs/DATABASE.md. Their primary keys are the opaque
// string ids Better Auth generates (a deliberate, documented exception to the
// UUID-v7 default: these rows are library-managed, not domain rows). `User` is
// modelled here — not hidden inside the auth library — so future domain tables
// (OrgMember, Invitation, …) can foreign-key to it and be organisation-scoped.
// ---------------------------------------------------------------------------

model User {
  id            String      @id
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions      Session[]
  accounts      Account[]
  memberships   OrgMember[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([identifier])
  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Tenancy foundation — Organization & OrgMember (ADR-0016).
//
// These are the canonical organisation-scoping models the whole product builds
// on. `OrgMember` is the single source of truth for "which user is in which
// organisation, with what role" — the scoping key every future feature's
// `principal.can(permission, organizationId)` check resolves against. Follows
// docs/DATABASE.md: UUID v7 PKs, snake_case columns via @map, timestamptz UTC,
// soft delete, audit columns, optimistic-locking `version`, scoped indexes.
// ---------------------------------------------------------------------------

// Organisation-scoped roles, least → most privileged. MUST stay in lock-step
// with the TypeScript `OrganizationRole` enum in
// apps/api/src/common/auth/principal.ts (ADR-0016). `EXTERNAL_GUEST` is
// deliberately NOT a member role (it is a per-plan share grant, modelled
// separately in a future ADR).
enum OrganizationRole {
  VIEWER
  CONTRIBUTOR
  PLANNER
  ORG_ADMIN
}

model Organization {
  id                  String               @id @default(uuid(7)) @db.Uuid
  name                String
  // URL-safe, unique per deployment, immutable in v1. Uniqueness is enforced by
  // a PARTIAL unique index that ignores soft-deleted rows (uq_organizations_slug
  // WHERE deleted_at IS NULL) — Prisma cannot express partial indexes, so it is
  // added as raw SQL in the migration. This index also serves slug lookups
  // (which always filter deleted_at IS NULL), so no separate @@index is needed.
  slug                String
  version             Int                  @default(1)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy           String?              @map("created_by")
  updatedBy           String?              @map("updated_by")
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamptz(3)
  members             OrgMember[]
  invitations         Invitation[]
  // Domain hierarchy owned by this organisation. Project/Plan back-relations
  // exist because those tables carry a denormalised organization_id FK (see the
  // Client/Project/Plan models below), not because the org is their direct
  // parent — the tree is Organization → Client → Project → Plan.
  clients             Client[]
  projects            Project[]
  plans               Plan[]
  activities          Activity[]
  // Denormalised scope back-relation: dependencies carry organization_id directly
  // (copied from their endpoints), like Activity — see the ActivityDependency model.
  dependencies        ActivityDependency[]
  // Org-scoped calendar library + its dated exceptions (M5, ADR-0024). Calendar's
  // organization_id is native (the org is its direct parent, like Client);
  // CalendarException's is denormalised from its parent calendar (like Activity).
  calendars           Calendar[]
  calendarExceptions  CalendarException[]
  // Org-scoped resource library + activity assignments (M7.1, ADR-0039). Resource's
  // organization_id is native (the org is its direct parent, like Calendar);
  // ResourceAssignment's is denormalised from its endpoints (like Activity/Dependency).
  resources           Resource[]
  resourceAssignments ResourceAssignment[]
  // Weighted activity-step checklists (M7 rung 5, ADR-0044). ActivityStep's
  // organization_id is denormalised from its parent activity (copied by the service,
  // never client input — the Activity/ResourceAssignment pattern).
  activitySteps       ActivityStep[]
  // Plan-of-record snapshots (M7, ADR-0025). Baseline's organization_id is
  // denormalised from its plan; BaselineActivity's from its parent baseline — both
  // copied by the service, never client input (the Activity pattern), so an org-scope
  // / IDOR check and the cascade batch filter one indexed column.
  baselines           Baseline[]
  baselineActivities  BaselineActivity[]
  // Ephemeral per-plan edit-lock coordination rows (ADR-0028). organization_id is
  // denormalised from the plan (copied by the service, never client input) purely as
  // a scope tag for scoped reads/audit; the row itself is owned by its plan.
  planLocks           PlanLock[]

  @@map("organizations")
}

model OrgMember {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  // FK → users.id. Better Auth generates opaque TEXT ids (NOT UUIDs), so this
  // column is plain `String` with NO @db.Uuid — it must match the TEXT PK it
  // references, otherwise the FK/migration fails.
  userId         String           @map("user_id")
  role           OrganizationRole
  version        Int              @default(1)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?          @map("created_by")
  updatedBy      String?          @map("updated_by")
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  // A user is an active member of an org at most once → enforced by a PARTIAL
  // unique index (uq_org_members_org_user ON (organization_id, user_id) WHERE
  // deleted_at IS NULL), added as raw SQL in the migration (Prisma cannot
  // express partial indexes). Re-adding a soft-deleted member is therefore
  // allowed.
  //
  // (organization_id, role) serves both "list an org's members" (leftmost
  // prefix on organization_id, also covering the FK) and the last-Org-Admin
  // count invariant; it subsumes a standalone organization_id index.
  @@index([organizationId, role])
  @@index([userId])
  @@map("org_members")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// An invitation to join an organisation with a role (ADR-0016). The raw token is
// never stored — only its hash (defence in depth); the raw value is returned once
// on create and emailed via the MailService port. A partial unique index keeps at
// most one PENDING invite per (organisation, email); expiry + status gate accept.
model Invitation {
  id               String           @id @default(uuid(7)) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  email            String
  role             OrganizationRole
  tokenHash        String           @unique @map("token_hash")
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime         @map("expires_at") @db.Timestamptz(3)
  acceptedByUserId String?          @map("accepted_by_user_id")
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz(3)
  version          Int              @default(1)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy        String?          @map("created_by")
  updatedBy        String?          @map("updated_by")
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Domain hierarchy — Client → Project → Plan (feature: hierarchy CRUD).
//
// The three organisation-scoped container levels every scheduling feature hangs
// off: an org owns Clients, a Client owns Projects, a Project owns Plans (a Plan
// is the future host of Activities and the TSLD canvas). All follow the same
// house standards as the tenancy models above: UUID v7 PKs, snake_case columns
// via @map, timestamptz UTC, NOT NULL by default, soft delete, audit columns,
// optimistic-locking `version`, and scoped indexes. See docs/DATABASE.md.
//
// Two cross-cutting conventions (recorded in docs/DECISIONS.md) apply here:
//
//   1. Denormalised `organization_id`. Project and Plan carry organization_id
//      directly (copied from their parent by the service layer inside the create
//      transaction, NEVER from client input) in addition to their parent FK, so
//      every scope/IDOR check and org-scoped query filters one indexed column
//      without a 2–3 table join. Invariant: a child's organization_id always
//      equals its parent's. Client's organization_id is native (the org is its
//      direct parent), not denormalised.
//
//   2. Cascade soft-delete + batch restore via `delete_batch_id`. There is no
//      DB cascade — deletes are soft and performed in the service layer. When a
//      row is soft-deleted, it and its whole active subtree are stamped in one
//      transaction with the same `delete_batch_id`, so restoring the parent
//      restores exactly that batch (and nothing that was deleted separately
//      earlier). Parent FKs stay ON DELETE RESTRICT: we never hard-delete, and
//      RESTRICT guards against an accidental hard delete orphaning children.
//
// Audit columns `created_by`/`updated_by` are plain TEXT (String, NO @db.Uuid):
// they hold Better Auth user ids, which are opaque TEXT, not UUIDs — mirroring
// OrgMember.userId. Typing them as uuid breaks inserts (it bit the prior slice).
// ---------------------------------------------------------------------------

// Lifecycle state of a Plan — plain metadata in this slice (no scheduling maths
// keys off it yet). MUST stay in lock-step with the TypeScript `PlanStatus` union
// in @repo/types.
enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// The plan-level scheduling mode (ADR-0033). Selects the canvas bar-x date source
// and the time-drag semantics: EARLY renders pure-network `early_*` and a drag
// imposes an explicit SNET + recalc (today's behaviour); VISUAL renders the
// engine's `visual_effective_*` and a drag writes the Planner's `visual_start`
// placement (no constraint) and pushes unplaced successors. Default EARLY is
// behaviour-preserving. MUST stay in lock-step with the TypeScript union in
// @repo/types (added in a later M3 task).
enum SchedulingMode {
  EARLY
  VISUAL
}

// How the CPM engine reschedules remaining work when progress is out of sequence
// (ADR-0035 §1, M2). RETAINED_LOGIC (default, behaviour-preserving in spirit) keeps
// incomplete-predecessor logic bounding an in-progress activity's remaining start;
// PROGRESS_OVERRIDE drops the incoming bound from incomplete predecessors (remaining
// runs from the data date); ACTUAL_DATES follows the ADR-0035 §1 actual-dates
// treatment. Stored now; the engine does not consume it until T2/T3. MUST stay in
// lock-step with the TypeScript `ProgressRecalcMode` union in @repo/types (added in
// a later M2 task).
enum ProgressRecalcMode {
  RETAINED_LOGIC
  PROGRESS_OVERRIDE
  ACTUAL_DATES
}

// How the CPM engine decides which activities are critical (ADR-0035 §17, M6 F2).
// TOTAL_FLOAT (default, P6/behaviour-preserving) marks an activity critical when its
// total float is at or below `critical_float_threshold`; LONGEST_PATH marks the
// driving chain back from the finish drivers instead. The engine consumes this in
// M6-F2. MUST stay in lock-step with the TypeScript `CriticalPathDefinition` union in
// @repo/types (added in a later M6 task).
enum CriticalPathDefinition {
  TOTAL_FLOAT
  LONGEST_PATH
}

// Which float an activity's total float is measured from (ADR-0035 §18, M6 F3).
// FINISH (default, P6/behaviour-preserving — the engine currently computes finish
// float) vs START vs SMALLEST (the smaller of the two). Stored now; the engine does
// not consume it until a later M6 task (F3). MUST stay in lock-step with the
// TypeScript `TotalFloatMode` union in @repo/types (added in a later M6 task).
enum TotalFloatMode {
  START
  FINISH
  SMALLEST
}

// The kind of schedule activity (PROJECT_BRIEF §8). Modelled up front so the
// deferred slices (dependencies, CPM, canvas) never need an enum migration.
// TASK + START/FINISH milestones are the everyday types the web UI exposes;
// LEVEL_OF_EFFORT is built (M5, ADR-0035 §21) — its span is DERIVED from an SS
// predecessor and an FF successor (the engine owns loeNoSpan when that span is
// missing); HAMMOCK is the same derived-duration idea and is still deferred (its
// engine wiring does not exist yet). WBS_SUMMARY (M5, ADR-0038) is a hierarchy
// SUMMARY: it carries NO logic (never an endpoint of a dependency edge) and its
// dates roll up from its branch's earliest start / latest finish (engine work is
// F6). RESOURCE_DEPENDENT (M7.1, ADR-0039 / ADR-0035 §23) is an activity that
// schedules on its DRIVING resource's calendar instead of its own (wired in M7.2);
// like LEVEL_OF_EFFORT / WBS_SUMMARY it is a first-class type, so `type` stays the
// single source of scheduling behaviour. MUST stay in lock-step with the
// `ActivityType` union in @repo/types (a separate task).
enum ActivityType {
  TASK
  START_MILESTONE
  FINISH_MILESTONE
  HAMMOCK
  LEVEL_OF_EFFORT
  WBS_SUMMARY
  RESOURCE_DEPENDENT
}

// The kind of a Resource (M7.1, ADR-0039). LABOUR = a crew / trade; EQUIPMENT =
// plant / machinery (the conformance fixture's NONLABOUR maps here); MATERIAL = a
// consumable quantity (concrete m³, steel te). A MATERIAL may be assigned to an
// activity but may NEVER be the driving resource of dates (drive is a labour/
// equipment concept) — a service invariant, not a DB constraint. MUST stay in
// lock-step with the TypeScript `ResourceKind` union in @repo/types (a separate task).
enum ResourceKind {
  LABOUR
  EQUIPMENT
  MATERIAL
}

// The P6 duration type of an activity (M7 rung 4, ADR-0040). It names which of the
// triad {Duration, Units, Units/Time} is RECOMPUTED (and which held) when a planner
// edits another, keeping the identity `Units = Duration × Units/Time` true. All four
// P6 values are modelled (the fixture uses all four): FIXED_DURATION_AND_UNITS_TIME
// (the dominant DEFAULT — duration & rate held, units absorb), FIXED_DURATION_AND_UNITS
// (duration & units held, rate absorbs), FIXED_UNITS (units held — duration derives on a
// rate edit), FIXED_UNITS_TIME (rate held — duration derives on a units edit). The
// recompute (`resolveTriad`) is a pure SERVICE-BOUNDARY concern resolved at write time,
// NOT the CPM engine (F2/F3); this slice is the definition column only. MUST stay in
// lock-step with the TypeScript `DurationType` union in @repo/types (F1).
enum DurationType {
  FIXED_DURATION_AND_UNITS_TIME
  FIXED_DURATION_AND_UNITS
  FIXED_UNITS
  FIXED_UNITS_TIME
}

// Progress state of an activity. Set via the progress path (Contributor+), never
// via the definition update.
enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

// The %-complete measure that feeds Earned Value for an activity (EV1, ADR-0042 /
// ADR-0035 §29). DURATION (default, behaviour-preserving — today's `percent_complete`
// is duration-based) derives EV performance % from elapsed vs total working time; UNITS
// from actual vs budgeted work (`actual_units / budgeted_units`); PHYSICAL from the
// hand-entered `physical_percent_complete`. It selects the EV performance measure ONLY —
// it NEVER changes a CPM date (physical/units %-complete earn value but move no dates;
// the schedule keeps using the M2 remaining duration). MUST stay in lock-step with the
// TypeScript `PercentCompleteType` union in @repo/types (EV1 Task 3).
enum PercentCompleteType {
  DURATION
  UNITS
  PHYSICAL
}

// The Estimate-at-Completion forecast method a plan's EV read uses (EV1, ADR-0042 /
// ADR-0035 §29, Q3). CPI (default, P6's "typical/performance-factor" EAC = BAC / CPI);
// REMAINING_AT_BUDGET (the "atypical" EAC = AC + (BAC − EV), remaining work at budget);
// CPI_TIMES_SPI (schedule-and-cost adjusted EAC = AC + (BAC − EV) / (CPI × SPI)). Read by
// the EV2 read module (a query param may override per-request); DARK in EV1. MUST stay in
// lock-step with the TypeScript `EacMethod` union in @repo/types.
enum EacMethod {
  CPI
  REMAINING_AT_BUDGET
  CPI_TIMES_SPI
}

// How an activity's expense lump-sum is recognised over time in the Earned-Value /
// cost read-model's PV & AC time-phasing (M7 rung 5, ADR-0044 §1 / ADR-0035 §32).
// It changes WHEN cost is recognised (the cost / cash-flow S-curve), NOT any CPM date
// and no engine column — EV is a pure read-model (ADR-0042). START recognises the full
// amount at the activity start (e.g. a crane mobilisation), END at the finish (e.g.
// retention), UNIFORM linearly (the DEFAULT — exactly today's linear phasing, so an
// unset value is byte-identical EV). MUST stay in lock-step with the `AccrualType`
// union in @repo/types.
enum AccrualType {
  START
  UNIFORM
  END
}

// The named P6 resource loading profile a resource assignment's budgeted_units is
// distributed by across the activity's duration (M7 rung 5, ADR-0044 §3 / ADR-0035
// §31). It shapes the resource histogram (a pure read-model, resource-histogram.ts) —
// it moves NO date and does NOT feed the levelling pass this rung (Q2). UNIFORM (the
// DEFAULT) is a flat load = today's byte-identical histogram; BELL peaks mid-span;
// FRONT_LOADED / BACK_LOADED weight the early / late span; DOUBLE_PEAK has two humps.
// The 21-point profile constants live in the read-model, not the DB. MUST stay in
// lock-step with the `ResourceCurveType` union in @repo/types.
enum ResourceCurveType {
  UNIFORM
  BELL
  FRONT_LOADED
  BACK_LOADED
  DOUBLE_PEAK
}

// Schedule constraint kinds (PROJECT_BRIEF §11). Reserved for the CPM engine
// (M6) — stored now so constraints round-trip before the engine honours them.
enum ConstraintType {
  SNET // start no earlier than
  SNLT // start no later than
  FNET // finish no earlier than
  FNLT // finish no later than
  MSO // must start on
  MFO // must finish on
  MANDATORY_START
  MANDATORY_FINISH
}

model Client {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  description    String?
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  // Correlation id (NOT a FK) shared by a row and every descendant soft-deleted
  // in the same operation; the unit of batch restore. Indexed by a partial index
  // (WHERE delete_batch_id IS NOT NULL) added as raw SQL in the migration.
  deleteBatchId  String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  projects     Project[]

  // Client name is unique per organisation among ACTIVE rows only — enforced by a
  // PARTIAL unique index (uq_clients_org_name ON (organization_id, name) WHERE
  // deleted_at IS NULL), added as raw SQL in the migration (Prisma cannot express
  // partial indexes). A soft-deleted name is therefore free to reuse.
  //
  // (organization_id, created_at, id) is a full composite that serves three
  // patterns at once: the organization_id FK (leftmost prefix), the org-scoped
  // active-list query, AND its deterministic cursor sort (ORDER BY created_at,
  // id). It subsumes a standalone organization_id index, so none is added.
  @@index([organizationId, createdAt, id])
  @@map("clients")
}

model Project {
  id             String    @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent client (see the block comment above). RESTRICT.
  organizationId String    @map("organization_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  name           String
  description    String?
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId  String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  plans        Plan[]

  // Project name is unique per CLIENT among ACTIVE rows — partial unique
  // (uq_projects_client_name ON (client_id, name) WHERE deleted_at IS NULL), raw
  // SQL in the migration. The same name may exist under a different client.
  //
  // (client_id, created_at, id) covers the client FK (leftmost prefix), the
  // list-projects-under-a-client query and its cursor sort in one; it subsumes a
  // standalone client_id index. organization_id is indexed on its own to back its
  // FK (RESTRICT) and org-scoped IDOR loads; there is no org-wide ordered project
  // list, so a single column suffices (no composite needed there).
  @@index([clientId, createdAt, id])
  @@index([organizationId])
  @@map("projects")
}

model Plan {
  id                          String                 @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent project (see the block comment above). RESTRICT.
  organizationId              String                 @map("organization_id") @db.Uuid
  projectId                   String                 @map("project_id") @db.Uuid
  name                        String
  description                 String?
  status                      PlanStatus             @default(DRAFT)
  // The scheduling mode (ADR-0033). Default EARLY is behaviour-preserving; a single-
  // row column read with the plan, never filtered across plans, so no index.
  schedulingMode              SchedulingMode         @default(EARLY) @map("scheduling_mode")
  // The out-of-sequence progress recalc mode (ADR-0035 §1, M2). Default
  // RETAINED_LOGIC is behaviour-preserving in spirit (the engine does not consume it
  // until T2/T3). Like scheduling_mode, a single-row column read with the plan, never
  // filtered across plans, so no index.
  progressRecalcMode          ProgressRecalcMode     @default(RETAINED_LOGIC) @map("progress_recalc_mode")
  // Expected-finish scheduling option (ADR-0035 §9, M4 F5). When true, the CPM engine's
  // forward pass recomputes an in-progress activity's remaining duration to land on its
  // `expected_finish` (the activity-level target date). Default false is behaviour-
  // preserving (the engine ignores expected finishes). Like scheduling_mode/
  // progress_recalc_mode, a single-row column read with the plan, never filtered across
  // plans, so no index; additive with a constant DEFAULT (no data migration).
  useExpectedFinishDates      Boolean                @default(false) @map("use_expected_finish_dates")
  // How criticality is decided (ADR-0035 §17, M6 F2). Default TOTAL_FLOAT is
  // P6/behaviour-preserving (total float <= critical_float_threshold). Like
  // scheduling_mode/progress_recalc_mode, a single-row column read with the plan, never
  // filtered across plans, so no index; additive with a constant DEFAULT (no data
  // migration). The engine (M6-F2) already consumes it. MUST stay in lock-step with the
  // TypeScript `CriticalPathDefinition` union in @repo/types.
  criticalPathDefinition      CriticalPathDefinition @default(TOTAL_FLOAT) @map("critical_path_definition")
  // The TOTAL_FLOAT criticality threshold in whole WORKING DAYS (day-denominated public
  // option, ADR-0036 §7; the service multiplies by 1440 to hand the engine working
  // minutes, mirroring duration_days<->duration_minutes). At/below this float an activity
  // is critical under TOTAL_FLOAT. Default 0 is P6/behaviour-preserving. Unconstrained
  // like the other option ints (0 and positive expected). Single-row column read with the
  // plan, never filtered across plans, so no index; additive with a constant DEFAULT.
  criticalFloatThreshold      Int                    @default(0) @map("critical_float_threshold")
  // Which float total float is measured from (ADR-0035 §18, M6 F3). Default FINISH is
  // the P6 default and behaviour-preserving (the engine currently computes finish float).
  // Stored now; the engine consumes it in a later M6 task (F3). Like scheduling_mode, a
  // single-row column read with the plan, never filtered across plans, so no index;
  // additive with a constant DEFAULT. MUST stay in lock-step with the TypeScript
  // `TotalFloatMode` union in @repo/types.
  totalFloatMode              TotalFloatMode         @default(FINISH) @map("total_float_mode")
  // Mark open-ended activities (no successors) critical (ADR-0035 §20, M6 F4). Default
  // false is P6/behaviour-preserving. Stored now; the engine consumes it in a later M6
  // task (F4). Like scheduling_mode, a single-row column read with the plan, never
  // filtered across plans, so no index; additive with a constant DEFAULT.
  makeOpenEndsCritical        Boolean                @default(false) @map("make_open_ends_critical")
  // Resource-levelling opt-in switch (ADR-0041 §7). When true (and the plan has
  // assignments), the recalc runs the opt-in second levelling pass that resolves
  // over-allocation into the engine-owned leveled_* overlay. Default FALSE is the
  // PARITY gate: off ⇒ the pass never runs and the recalc is byte-identical to today
  // (no server feature flag needed — the ADR-0040 opt-in precedent). Like
  // scheduling_mode/use_expected_finish_dates, a single-row column read with the plan,
  // never filtered across plans, so no index; additive with a constant DEFAULT (no data
  // migration). Consumed by the L2 engine pass; dark in this L1 slice.
  levelResources              Boolean                @default(false) @map("level_resources")
  // Level-within-float-only option (ADR-0041 §4, matching P6's off-by-default "level
  // only within float"). When true, levelling may delay an activity only WITHIN its
  // total float (preserving the project finish) and never EXTENDS the schedule; any
  // residual over-allocation is flagged rather than resolved. Default FALSE is
  // behaviour-preserving (and only relevant when level_resources is on). Like the other
  // plan options, a single-row column read with the plan, never filtered across plans,
  // so no index; additive with a constant DEFAULT. Consumed by the L2 engine pass.
  levelWithinFloatOnly        Boolean                @default(false) @map("level_within_float_only")
  // Ignore-external scheduling option (ADR-0043 / ADR-0035 §30.4, M1). When true the
  // recalc DROPS every activity's external_early_start AND external_late_finish (the P6
  // "ignore relationships to/from other projects" toggle), leaving internal
  // constraints/logic untouched — so the planner can compare the plan on its OWN logic
  // vs. GATED by its neighbours (scenario S09). Default FALSE is behaviour-preserving
  // (external bounds honoured, and inert when no activity carries one). Mirrors
  // make_open_ends_critical / level_resources: a single-row plan column read with the
  // plan, never filtered across plans (so no index); additive with a constant DEFAULT
  // (no data migration, byte-parity). MUST stay in lock-step with @repo/types.
  ignoreExternalRelationships Boolean                @default(false) @map("ignore_external_relationships")
  // The Earned-Value EAC forecast method (EV1, ADR-0042, Q3). Default CPI is P6's headline
  // forecast (EAC = BAC / CPI). Read by the EV2 read module (a query param may override
  // per-request); DARK in EV1 — nothing computes EV yet. Like the other plan options a
  // single-row column read with the plan, never filtered across plans, so no index;
  // additive with a constant DEFAULT (no data migration, byte-parity). MUST stay in
  // lock-step with the TypeScript `EacMethod` union in @repo/types.
  eacMethod                   EacMethod              @default(CPI) @map("eac_method")
  // The plan's ISO-4217 currency for all money columns (EV1, ADR-0042, Q6). Single currency
  // per plan (multi-currency/FX is out of scope — CLAUDE.md §17). CHAR(3) is a genuine
  // fixed-width code (the docs/DATABASE.md "text unless a real limit applies" exception),
  // guarded by ck_plans_currency_code_iso4217 (nullable-safe uppercase 3-letter format).
  // NULLABLE with NO default — NULL = unset / inherit the org default at read time; a
  // DEFAULT currency is deliberately omitted so we never stamp an arbitrary currency (e.g.
  // USD) on an existing GBP plan. Money reads as minor units + this code. Single-row column
  // read with the plan, never filtered across plans, so no index; additive, byte-parity.
  // Client-settable.
  currencyCode                String?                @map("currency_code") @db.Char(3)
  // Date-only (no time / no timezone): a plan's start is a calendar day, not an
  // instant, so it is @db.Date, not timestamptz. This IS the CPM data date
  // (ADR-0023). **Required + NOT NULL** as of ADR-0033 **M1** — the
  // …_require_plan_planned_start migration backfilled every prior NULL (earliest
  // active constraint_date → earliest active actual_start → created_at::date →
  // today) then SET NOT NULL. That was the feature's one irreversible migration.
  plannedStart                DateTime               @map("planned_start") @db.Date
  // The plan's default working-day calendar (M5, ADR-0024). Nullable → all-days-work
  // (M6 back-compat); new plans default to the org's seeded Standard calendar. FK is
  // RESTRICT (calendars soft-delete only; the service in-use guard returns 409
  // CALENDAR_IN_USE before any delete). Backed by a partial index on (calendar_id)
  // WHERE deleted_at IS NULL — raw SQL in the migration.
  calendarId                  String?                @map("calendar_id") @db.Uuid
  version                     Int                    @default(1)
  createdAt                   DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy                   String?                @map("created_by")
  updatedBy                   String?                @map("updated_by")
  deletedAt                   DateTime?              @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId               String?                @map("delete_batch_id") @db.Uuid

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Restrict)
  calendar     Calendar?            @relation(fields: [calendarId], references: [id], onDelete: Restrict)
  activities   Activity[]
  // Dependencies contained in this plan (denormalised plan_id = both endpoints' plan).
  dependencies ActivityDependency[]
  // Plan-of-record snapshots captured from this plan (M7, ADR-0025). At most one is
  // active at a time (partial unique in the migration). FK is RESTRICT; baseline
  // soft-delete + cascade is service-owned (HierarchyLifecycleService).
  baselines    Baseline[]
  // The (optional) edit-lock row for this plan (ADR-0028). 1:1 — PlanLock's PK IS the
  // plan id, so presence = someone holds the pen, absence = free. FK is ON DELETE
  // CASCADE (the lock is ephemeral state owned by the plan, not a soft-deleted domain
  // record), so a plan hard-purge removes it and is never blocked by a stale lock.
  planLock     PlanLock?

  // Plan name is unique per PROJECT among ACTIVE rows — partial unique
  // (uq_plans_project_name ON (project_id, name) WHERE deleted_at IS NULL), raw
  // SQL in the migration.
  //
  // (project_id, created_at, id) covers the project FK, the list-plans-under-a-
  // project query and its cursor sort; subsumes a standalone project_id index.
  // organization_id is indexed on its own for its FK and org-scoped IDOR loads.
  @@index([projectId, createdAt, id])
  @@index([organizationId])
  @@map("plans")
}

// An Activity — the atomic unit of a schedule (PROJECT_BRIEF §9), the leaf of the
// Client → Project → Plan → Activity hierarchy. Org-scoped via a denormalised
// organization_id copied from the parent plan (never client input), following the
// Project/Plan pattern. The full field set is persisted now — including the
// CPM output columns and the graphical lane — so the deferred slices (M4
// dependencies, M5 calendars, M6 CPM engine, M7 TSLD canvas) are additive with no
// wide migration. The CPM columns are engine-owned: nullable/defaulted, never
// accepted from write DTOs, populated by the M6 engine.
model Activity {
  id             String @id @default(uuid(7)) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  planId         String @map("plan_id") @db.Uuid

  // Definition (Planner-owned).
  code                     String?
  name                     String
  description              String?
  type                     ActivityType    @default(TASK)
  // Working MINUTES of work (ADR-0036); milestones are 0. The public API is still
  // day-denominated (ADR-0036 §7) — the service scales days↔minutes at the boundary.
  // A ck_activities_duration_minutes_nonneg (>= 0) CHECK is raw SQL in the migration.
  durationMinutes          Int             @default(480) @map("duration_minutes")
  // The activity's own working-time calendar (M5, ADR-0037). Nullable → inherit the
  // plan default (resolution: activity.calendarId → plan.calendarId → all-minutes).
  // Client-settable, but the FK alone does NOT enforce same-org — a cross-org
  // calendarId satisfies the FK, so the org-scope check stays in the service (like the
  // plan picker). FK is RESTRICT (calendars soft-delete only; the CALENDAR_IN_USE
  // service guard, which now unions active plans + active activities, is the real
  // protection — RESTRICT is defence in depth). Backed by a partial index on
  // (calendar_id) WHERE deleted_at IS NULL — raw SQL in the migration.
  calendarId               String?         @map("calendar_id") @db.Uuid
  constraintType           ConstraintType? @map("constraint_type")
  // Calendar day (date-only, no timezone), like Plan.plannedStart.
  constraintDate           DateTime?       @map("constraint_date") @db.Date
  // Secondary schedule constraint (ADR-0035 §10, M4 F3). Same shape as the primary
  // pair above and equally client-settable (NOT engine-owned): the primary drives
  // the forward pass, this secondary drives the backward pass. Both-null-or-both-set
  // is enforced by ck_activities_secondary_constraint_pair (raw SQL in the migration,
  // like the primary — Prisma can't express a CHECK). Unindexed like the primary:
  // read only on the full-plan recalc load, never filtered/sorted on.
  secondaryConstraintType  ConstraintType? @map("secondary_constraint_type")
  // Calendar day (date-only, no timezone), like constraint_date.
  secondaryConstraintDate  DateTime?       @map("secondary_constraint_date") @db.Date
  // External / inter-project dates (ADR-0043 / ADR-0035 §30, M1). Two imported absolute
  // working-instants (TIMESTAMPTZ, the ADR-0037 axis — NOT calendar days like
  // constraint_date) gating this activity from ANOTHER project: external_early_start is
  // an SNET-shaped forward LOWER bound (the earliest an upstream project hands this
  // over); external_late_finish an FNLT-shaped backward UPPER bound (the latest a
  // downstream project allows it to finish). CLIENT-SETTABLE (a write DTO sets them),
  // NOT engine-owned; either, both, or neither may be set. Stored ABSOLUTELY (a vendor /
  // interface commitment, independent of THIS plan's data date — hence @db.Timestamptz,
  // not @db.Date), so a data-date change never moves them. Soft bounds, never mandatory
  // PINS: the engine clamps early start UP to / late finish DOWN to them on the existing
  // forward/backward passes (gated on plan.ignore_external_relationships), never setting
  // constraint_violated. NULL = no external bound (the byte-parity default). N26
  // (external_late_finish before external_early_start when BOTH set) is a DTO 422
  // (EXTERNAL_FINISH_BEFORE_START) backed by the nullable-safe DB CHECK
  // ck_activities_external_finish_after_start (raw SQL in the migration — Prisma cannot
  // express a CHECK; the ck_activities_resume_after_suspend precedent). No index: read
  // only on the full-plan recalc load ((plan_id, created_at, id)), never a query
  // predicate (the secondary_constraint / expected_finish precedent).
  externalEarlyStart       DateTime?       @map("external_early_start") @db.Timestamptz(3)
  externalLateFinish       DateTime?       @map("external_late_finish") @db.Timestamptz(3)
  // The P6 duration type (M7 rung 4, ADR-0040) — which of {Duration, Units, Units/Time}
  // is recomputed vs held when a planner edits another, keeping `Units = Duration ×
  // Units/Time` true. CLIENT-SETTABLE definition column (a Planner picks it, like `type`/
  // `constraint_type`), NOT engine-owned. The recompute (`resolveTriad`) is a pure
  // service-boundary concern (F2/F3); the CPM engine is untouched — it reads the resolved
  // `duration_minutes`. Default FIXED_DURATION_AND_UNITS_TIME (the fixture's dominant
  // value) backfills every existing row, so the byte-parity golden path is unchanged.
  // No index: read only on the full-plan recalc load, never a query predicate (the
  // secondary_constraint_type precedent). MUST stay in lock-step with the TypeScript
  // `DurationType` union in @repo/types.
  durationType             DurationType    @default(FIXED_DURATION_AND_UNITS_TIME) @map("duration_type")
  // Graphical y-lane / vertical offset for the TSLD canvas (M7); part of the
  // persisted model per PROJECT_BRIEF §9, not a runtime concern.
  laneIndex                Int             @default(0) @map("lane_index")
  // As-late-as-possible placement preference (ADR-0035 §11, M4 F4). CLIENT-SETTABLE
  // Planner input (a user-facing write DTO sets it) — NOT engine-owned. It is a
  // DISPLAY-ONLY placement preference: the ALAP pass sets the activity's shown start
  // as late as its successors allow, leaving the pure early_*/late_*/total_float
  // network untouched (the effective-Visual precedent). Defaulted false backfills
  // every existing row, so the byte-parity golden path is unchanged. No index: read
  // only on the full-plan recalc load, never a query predicate.
  scheduleAsLateAsPossible Boolean         @default(false) @map("schedule_as_late_as_possible")
  // The resource-levelling TIE-BREAK input (ADR-0041 §1). LOWER = HIGHER priority: when
  // two activities contend for a capacity-constrained resource, the serial priority-list
  // pass places the lower `leveling_priority` first (then total-float asc → early-start
  // asc → id asc). CLIENT-SETTABLE Planner input (a write DTO sets it), NOT engine-owned.
  // NULLABLE with NO default — NULL = UNSET (the planner has expressed no preference),
  // distinct from an explicit 0 (which, lower=higher, would mean "top priority"). The
  // engine defines NULL ordering (NULL sorts LAST / neutral, after every explicit value),
  // documented in ADR-0035 §28. Nullable-no-default mirrors the other optional Planner
  // inputs (expected_finish / visual_start): a DEFAULT is deliberately omitted so we
  // never conflate "unset" with an arbitrary sentinel priority, and existing rows read
  // NULL (metadata-only add, no backfill, byte-parity). No index — read only on the
  // full-plan recalc load, never a query predicate (plan-scoped load only). MUST stay in
  // lock-step with @repo/types. LEVELLING-READ ONLY when the plan opts in; dark until L2.
  levelingPriority         Int?            @map("leveling_priority")

  // Progress (Contributor-updatable via the progress path).
  status                   ActivityStatus @default(NOT_STARTED)
  percentComplete          Int            @default(0) @map("percent_complete")
  actualStart              DateTime?      @map("actual_start") @db.Date
  actualFinish             DateTime?      @map("actual_finish") @db.Date
  // Independent remaining duration in working MINUTES (ADR-0035, M2; P6-faithful,
  // matches the fixture's `remaining_duration_h`). NULL ⇒ the engine DERIVES remaining
  // from `percent_complete × duration_minutes`; non-null ⇒ this explicit remaining is
  // used verbatim (decoupled from percent, so out-of-sequence productivity is faithful
  // and the negative case N18 — remaining > 0 on a complete activity — is detectable).
  // Day-denominated at the API boundary (ADR-0036 §7). A ck_activities_remaining_duration
  // _minutes_nonneg (>= 0) CHECK is raw SQL in the migration (mirrors duration_minutes).
  remainingDurationMinutes Int?           @map("remaining_duration_minutes")
  // Suspend/resume (ADR-0035 §4, M2; engine wiring in T7). Calendar days (date-only,
  // like actual_start/finish). A suspended activity's remaining work is floored at
  // `max(data date, resume_date)`. A ck_activities_resume_after_suspend (nullable-safe:
  // resume_date IS NULL OR suspend_date IS NULL OR resume_date >= suspend_date) CHECK is
  // raw SQL in the migration.
  suspendDate              DateTime?      @map("suspend_date") @db.Date
  resumeDate               DateTime?      @map("resume_date") @db.Date
  // Expected finish (ADR-0035 §9, M4 F5). A CLIENT-SETTABLE target finish date for an
  // in-progress activity (calendar day, date-only like actual_start/finish) — NOT
  // engine-owned. When the plan option `use_expected_finish_dates` is on, the engine's
  // forward pass recomputes this activity's remaining duration so its early finish lands
  // on this date (floored per the M2 data-date rule); off (or NULL) ⇒ ignored. Nullable
  // with no default ⇒ every existing row reads "no expected finish" and the byte-parity
  // golden path is unchanged. No index: read only on the full-plan recalc load.
  expectedFinish           DateTime?      @map("expected_finish") @db.Date

  // Earned Value inputs (EV1, ADR-0042 / ADR-0035 §29). All additive & behaviour-
  // preserving: EV is a pure READ-MODEL (EV2) — none of these feed the CPM engine, and an
  // unset value leaves every recalc/progress/baseline path byte-identical. DARK in EV1
  // (nothing reads them yet). Money is BIGINT minor units in the plan's `currency_code`
  // (docs/DATABASE.md: money = integer minor units + currency).
  //   * percent_complete_type — CLIENT-SETTABLE definition (a Planner picks it, like `type`/
  //     `duration_type`). Selects which measure feeds EV performance %: DURATION (default,
  //     behaviour-preserving), UNITS, or PHYSICAL. It NEVER changes a CPM date. Constant
  //     DEFAULT backfills every row (byte-parity).
  //   * physical_percent_complete — CONTRIBUTOR progress input, used only when
  //     percent_complete_type = PHYSICAL. SMALLINT 0–100, NULLABLE / NO default (NULL =
  //     unset, distinct from an explicit 0). ck_activities_physical_percent_complete_range
  //     (nullable-safe 0–100) is the DB backstop behind the DTO 0–100 reject (N23).
  //   * budgeted_expense — CLIENT-SETTABLE definition: an optional activity-level lump-sum
  //     budget for non-resourced work (BAC = Σ assignment cost + this). BIGINT minor units,
  //     NULLABLE / NO default (NULL = no expense, contributes 0 — parity).
  //   * actual_expense — CONTRIBUTOR progress: the lump-sum actual spent. BIGINT minor
  //     units, NULLABLE / NO default (NULL = none). Both expenses are guarded `>= 0`
  //     (nullable-safe) by ck_activities_budgeted_expense_nonneg / _actual_expense_nonneg (N22).
  // No index: read only on the plan-scoped EV load ((plan_id, created_at, id)), never a
  // query predicate (the secondary_constraint_type / expected_finish precedent). MUST stay
  // in lock-step with @repo/types.
  percentCompleteType     PercentCompleteType @default(DURATION) @map("percent_complete_type")
  physicalPercentComplete Int?                @map("physical_percent_complete") @db.SmallInt
  budgetedExpense         BigInt?             @map("budgeted_expense")
  actualExpense           BigInt?             @map("actual_expense")
  // Cost accrual (M7 rung 5, ADR-0044 §1 / ADR-0035 §32). CLIENT-SETTABLE definition: how
  // this activity's expense lump-sum is time-phased in the EV/cost read-model's PV & AC —
  // START (all at the activity start), UNIFORM (linear), END (all at the finish). It
  // changes WHEN cost is recognised (the cost S-curve), never a CPM date and no engine
  // column (EV is a pure read-model, ADR-0042). Constant DEFAULT UNIFORM = today's linear
  // phasing, so every existing row backfills to byte-identical EV (the parity gate). No
  // index: read only on the plan-scoped EV load ((plan_id, created_at, id)), never a query
  // predicate (the percent_complete_type precedent). MUST stay in lock-step with @repo/types.
  accrualType             AccrualType         @default(UNIFORM) @map("accrual_type")

  // WBS hierarchy — the adjacency-list parent link (M5, ADR-0038). A nullable
  // self-FK: null = a top-level activity (no WBS parent); non-null = this activity
  // is grouped under the referenced WBS_SUMMARY. The parent tree groups activities
  // into a Work Breakdown Structure and is ORTHOGONAL to the dependency DAG
  // (ADR-0021) — a WBS parent is NOT a logic tie. Three invariants live in the
  // service (the FK alone cannot express them): (a) the parent tree is ACYCLIC — no
  // activity is its own ancestor (a service-layer ancestor walk on reparent; the
  // ck_activities_parent_not_self CHECK, raw SQL in the migration, backs only the
  // trivial self-parent parent_id <> id); (b) parent and child share the SAME plan
  // AND organization (the FK scopes only to `activities`, not to a plan); (c) only a
  // WBS_SUMMARY may be a parent and a SUMMARY carries NO logic (never a dependency
  // endpoint — ADR-0035 §24). Client-settable. onDelete: Restrict — a summary with
  // children can never be hard-deleted out from under them (defence in depth; the
  // real delete path is the service-owned cascade soft-delete, which stamps the
  // summary and its whole active subtree with one delete_batch_id, ADR-0038). Rollup
  // (a summary's dates = its branch's earliest start / latest finish) is engine work
  // (F6); this slice is schema + validation only. Backed by the partial index on
  // (parent_id) WHERE deleted_at IS NULL — raw SQL in the migration.
  parentId String? @map("parent_id") @db.Uuid

  // CPM output — engine-owned (M6). Nullable/defaulted; never set from input.
  earlyStart            DateTime? @map("early_start") @db.Date
  earlyFinish           DateTime? @map("early_finish") @db.Date
  lateStart             DateTime? @map("late_start") @db.Date
  lateFinish            DateTime? @map("late_finish") @db.Date
  totalFloat            Int?      @map("total_float")
  // Free float in whole working days (ADR-0035 §17–§20, M6-F1; day-denominated public
  // column per ADR-0036 §7). Engine-owned CPM output exactly like total_float:
  // written ONLY by the recalc's batched `unnest` UPDATE (schedule.repository
  // writeResults), NEVER accepted from a write DTO, and NEVER touching version/
  // updated_at/updated_by so a recalc stays invisible to optimistic locking
  // (ADR-0022). Free float is normally >= 0 (0 is valid) and never negative in
  // practice, but the column is unconstrained — no CHECK — mirroring total_float.
  // Nullable with no default ⇒ every existing row reads NULL ("not yet calculated"),
  // so no backfill is needed and the byte-parity golden path is unchanged. No index:
  // read only as part of the already plan-scoped activity load ((plan_id, created_at,
  // id)); no query filters or sorts by it (docs/DATABASE.md: index query patterns,
  // not columns).
  freeFloat             Int?      @map("free_float")
  isCritical            Boolean   @default(false) @map("is_critical")
  isNearCritical        Boolean   @default(false) @map("is_near_critical")
  // Produce-and-flag violation output (ADR-0035 §7 amendment, M4). True when a mandatory
  // pin (MANDATORY_START/MANDATORY_FINISH) overrode a stronger logic bound — a forward pin
  // earlier than the network-earliest, or a backward pin that forced negative float. This
  // un-parks the old silent MSO/MFO treatment: the engine produces the (possibly impossible)
  // schedule and flags it, never repairs it. Engine-owned exactly like is_critical:
  // defaulted false, never accepted from a write DTO, written only by the recalc's batched
  // `unnest` UPDATE alongside the CPM columns above (never touching version/updated_at/
  // updated_by, ADR-0022). Reads false until the plan is first calculated AND on the
  // no-mandatory / all-inherit path, so existing rows stay byte-identical. No index: read
  // as part of the already plan-scoped activity load ((plan_id, created_at, id)) and
  // aggregated over that scope (constraintViolationCount) — no predicate targets it; a
  // low-cardinality boolean index would only cost writes (mirrors is_critical/is_driving).
  constraintViolated    Boolean   @default(false) @map("constraint_violated")
  // External-driven produce-and-flag output (ADR-0043 M1 / ADR-0035 §30.3). True when an imported
  // external bound drove this activity's schedule this recalc — its external early-start was the
  // binding forward bound, or its external late-finish the binding backward bound. The per-activity
  // companion to the plan-level externalDrivenCount; the soft-bound analogue of constraint_violated.
  // Engine-owned exactly like constraint_violated: defaulted false, never accepted from a write DTO,
  // written only by the recalc's batched `unnest` UPDATE alongside the CPM columns (ADR-0022). Reads
  // false until first calculated AND on the no-external path, so existing rows stay byte-identical.
  // No index (mirrors constraint_violated) — read within the plan-scoped activity load, no predicate.
  externalDriven        Boolean   @default(false) @map("external_driven")
  // LOE no-span produce-and-flag output (ADR-0035 §21 / N12, M5). True when a
  // LEVEL_OF_EFFORT activity has no resolvable span — missing an SS predecessor or an
  // FF successor — so the engine cannot derive its start/finish from the activities it
  // spans. Rather than rejecting, the engine places the span-less LOE at its defined
  // fallback and flags it, never repairs it. Engine-owned exactly like
  // constraint_violated/is_critical: defaulted false, never accepted from a write DTO,
  // written only by the recalc's batched `unnest` UPDATE alongside the CPM columns above
  // (never touching version/updated_at/updated_by, ADR-0022). Reads false until the plan
  // is first calculated AND on the no-LOE / all-inherit path, so existing rows stay
  // byte-identical. No index: read as part of the already plan-scoped activity load
  // ((plan_id, created_at, id)) and aggregated over that scope — no predicate targets it;
  // a low-cardinality boolean index would only cost writes (mirrors constraint_violated).
  loeNoSpan             Boolean   @default(false) @map("loe_no_span")
  // RESOURCE_DEPENDENT driver-missing produce-and-flag output (M7, ADR-0035 §23 /
  // ADR-0039 rung 2). True when a RESOURCE_DEPENDENT activity has no resolvable
  // driving resource (0 or >1 driving assignments, or a driver with no calendar) so
  // the engine falls back to the activity calendar. Engine-owned EXACTLY like
  // loe_no_span / constraint_violated: defaulted false, NEVER accepted from a write
  // DTO, written only by the recalc's batched `unnest` UPDATE (never touching version/
  // updated_at/updated_by, ADR-0022). The column lands NOW (additive; reads false
  // everywhere until an activity is made resource-dependent, so the byte-parity golden
  // path is unchanged) so the M7.2 rung-2 slice needs no wide ALTER of the large
  // activities table; its WRITER is the M7.2 engine task (F4.T2), not this slice. No
  // index: read as part of the already plan-scoped activity load ((plan_id, created_at,
  // id)) and aggregated over that scope (resourceDriverMissingCount) — no predicate
  // targets it; a low-cardinality boolean index would only cost writes (mirrors loe_no_span).
  resourceDriverMissing Boolean   @default(false) @map("resource_driver_missing")

  // Visual Planning placement (ADR-0033). `visual_start` is the ONLY Planner-owned
  // input here — the hand-placed calendar day a DTO may set (date-only, like
  // constraint_date). It feeds ONLY the engine's second, forward-only effective-
  // Visual pass, never the pure-network pass, so it can never corrupt early_*/float.
  visualStart DateTime? @map("visual_start") @db.Date

  // Effective-Visual output — engine-owned (ADR-0033), written ONLY by the recalc's
  // batched `unnest` UPDATE alongside the CPM columns above; NEVER accepted from a
  // DTO and NEVER touching version/updated_at/updated_by (ADR-0022 property
  // preserved). `visual_effective_start/finish` are what Visual mode renders (a
  // placed bar sits on its visual_start; an unplaced one at its effective-earliest).
  // `visual_conflict` flags an infeasible placement (stay-and-flag, SQ-a);
  // `visual_drift_days` = visual_start − pure-network early_start (working days).
  // Nullable/defaulted, mirroring early_*/is_critical. No index: read as part of the
  // already plan-scoped activity load ((plan_id, created_at, id)) and aggregated over
  // that scope (conflictCount) — no predicate targets them; a partial "list
  // conflicts" index is an explicit ADR-0033 follow-up if a conflicts panel lands.
  visualEffectiveStart  DateTime? @map("visual_effective_start") @db.Date
  visualEffectiveFinish DateTime? @map("visual_effective_finish") @db.Date
  visualConflict        Boolean   @default(false) @map("visual_conflict")
  visualDriftDays       Int?      @map("visual_drift_days")

  // Resource-levelling OVERLAY — engine-owned (ADR-0041 §3, Q2). The opt-in second pass
  // (plans.level_resources) runs AFTER the pure CPM network pass and produces these
  // additive leveled positions; the pure early_*/late_*/total_float/is_critical are
  // NOT recomputed on the leveled dates (network float stays authoritative — ADR-0041
  // Q2). Written ONLY by the recalc's batched `unnest` UPDATE alongside the CPM columns
  // above; NEVER accepted from a write DTO and NEVER touching version/updated_at/
  // updated_by (the ADR-0022 engine-owned-column contract), exactly like early_*/
  // is_critical/constraint_violated/resource_driver_missing.
  //   * leveled_start/leveled_finish — the delayed positions the levelling pass placed
  //     this activity at (calendar day, date-only like early_start/early_finish).
  //     Nullable/no-default ⇒ NULL = "not levelled" (levelling off, or the plan has no
  //     over-allocation), mirroring early_start/early_finish.
  //   * leveling_delay_minutes — the applied delay in WORKING MINUTES on the activity's
  //     own calendar (leveled_start − early_start; day-denominated at the API boundary,
  //     ADR-0036 §7). Nullable/no-default ⇒ NULL = "not yet levelled", mirroring the
  //     engine-owned nullable ints total_float/free_float/visual_drift_days.
  //   * leveling_window_exceeded — produce-and-flag bool (ADR-0041 §6, Q1 =
  //     extend-past-window-and-flag): true when serialising pushed this activity PAST a
  //     resource's availability window (e.g. the crane-hire window's end); the engine
  //     extends and FLAGS, never hangs, never silently succeeds. Mirrors
  //     constraint_violated exactly (defaulted false, engine-owned).
  //   * self_over_allocated — produce-and-flag bool (ADR-0041 §2): true when this
  //     activity's OWN single-activity demand exceeds the resource capacity — an
  //     over-allocation delay cannot fix (not split in this rung); reported, never
  //     resolved. Mirrors constraint_violated/resource_driver_missing exactly.
  // All read false/NULL until the plan opts in AND is first levelled, so existing rows
  // stay byte-identical (parity). No index: read as part of the already plan-scoped
  // activity load ((plan_id, created_at, id)) and the bools aggregated over that scope
  // (plan-level counts, computed in the schedule summary — no plan column, the
  // constraint_violated precedent); no predicate targets them, and a low-cardinality
  // boolean index would only cost writes. Dark until L2 wires the pass.
  leveledStart           DateTime? @map("leveled_start") @db.Date
  leveledFinish          DateTime? @map("leveled_finish") @db.Date
  levelingDelayMinutes   Int?      @map("leveling_delay_minutes")
  levelingWindowExceeded Boolean   @default(false) @map("leveling_window_exceeded")
  selfOverAllocated      Boolean   @default(false) @map("self_over_allocated")

  // Housekeeping (as Project/Plan): TEXT audit ids (Better Auth ids are TEXT),
  // optimistic-lock version, soft delete + restore-batch correlation.
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  // The activity's own working-time calendar (M5, ADR-0037) — mirrors Plan.calendar
  // exactly (nullable, onDelete: Restrict). null = inherit the plan default.
  calendar     Calendar?    @relation(fields: [calendarId], references: [id], onDelete: Restrict)

  // The dependency edges incident on this activity (M4). Two named self-relations
  // on ActivityDependency point back here: `predecessorLinks` are the edges where
  // this activity is the PREDECESSOR (its successors), `successorLinks` where it is
  // the SUCCESSOR (its predecessors). Explicit relation names are required because
  // ActivityDependency has two FKs to `activities` — Prisma cannot disambiguate them
  // otherwise. Both FKs are RESTRICT; link soft-delete is service-owned (see A3).
  predecessorLinks ActivityDependency[] @relation("DependencyPredecessor")
  successorLinks   ActivityDependency[] @relation("DependencySuccessor")

  // The WBS adjacency-list self-relation (M5, ADR-0038): `parent` is this activity's
  // WBS_SUMMARY container (null = top-level), `children` are the activities grouped
  // under it (empty for a leaf). onDelete: Restrict guards against an accidental hard
  // delete orphaning children; the normal delete is the service-owned cascade
  // soft-delete (delete_batch_id), never a DB CASCADE. Same-plan/same-org and
  // acyclicity are service-enforced (see the parentId comment above).
  parent   Activity?  @relation("ActivityHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children Activity[] @relation("ActivityHierarchy")

  // Resource assignments on this activity (M7.1, ADR-0039). RESTRICT FK; assignments
  // soft-delete only. Soft-deleting an activity SHOULD sweep its active assignments
  // (stamped with the same delete_batch_id, mirroring the incident-dependency cascade)
  // — a HierarchyLifecycleService follow-on (a later task, not this schema slice).
  assignments ResourceAssignment[]

  // Weighted checklist steps on this activity (M7 rung 5, ADR-0044 §2). RESTRICT FK;
  // steps soft-delete only. Soft-deleting an activity SHOULD sweep its active steps
  // (stamped with the same delete_batch_id, mirroring the assignment sweep above) — a
  // HierarchyLifecycleService follow-on for the F2 build, NOT this schema slice.
  steps ActivityStep[]

  // Activity name (and, when present, code) are unique per PLAN among ACTIVE rows
  // — partial uniques (uq_activities_plan_name, uq_activities_plan_code WHERE
  // deleted_at IS NULL [AND code IS NOT NULL]), raw SQL in the migration.
  //
  // (plan_id, created_at, id) covers the plan FK, the list-activities-under-a-plan
  // query and its cursor sort in one. organization_id is indexed on its own for
  // its FK (RESTRICT) and org-scoped IDOR loads.
  //
  // (parent_id) backs the parent self-FK (RESTRICT) and the "children of this
  // summary" load the rollup + navigator walk over. It is a PARTIAL index filtered
  // on deleted_at IS NULL (raw SQL in the migration — Prisma cannot express the
  // WHERE): only the minority of rows that are grouped under a summary and live
  // carry a value, so the partial keeps it tiny (the delete_batch_id / calendar_id
  // partial-index precedent). The @@index below declares it to Prisma; the migration
  // replaces it with the partial form.
  @@index([planId, createdAt, id])
  @@index([organizationId])
  @@index([parentId])
  @@map("activities")
}

// The four CPM/GPM relationship types between two activities (PROJECT_BRIEF §10).
// MUST stay in lock-step with the TypeScript `DependencyType` union in @repo/types
// (A2). FS = finish-to-start (default), SS = start-to-start, FF = finish-to-finish,
// SF = start-to-finish. The type does not affect the acyclicity check (a cycle is a
// structural property of the edges); it and the signed lag are what the M6 CPM engine
// reads to compute dates.
enum DependencyType {
  FS
  SS
  FF
  SF
}

// The calendar on which a relationship's lag is measured (ADR-0036 §6) — a per-relationship
// override of the P6 "calendar for scheduling relationship lag" setting. M1 lands the column
// (the seam); M3 wires resolution + the 24-hour override. PREDECESSOR/SUCCESSOR resolve
// against the endpoint's effective calendar (= the plan calendar until per-activity calendars
// land). Kept in lock-step with the LagCalendarSource union in @repo/types.
enum LagCalendarSource {
  PREDECESSOR
  SUCCESSOR
  TWENTY_FOUR_HOUR
  PROJECT_DEFAULT
}

// An ActivityDependency — a typed, lagged logic edge between two activities in a plan
// (PROJECT_BRIEF §10), turning a Plan's flat list of activities into a schedule
// network (a directed graph). The complete edge the CPM engine (M6) reads: `type`
// + signed `lag_days`. Follows every house standard (UUID v7 PK, snake_case via @map,
// timestamptz UTC, NOT NULL by default, soft delete, audit, optimistic-locking
// `version`, scoped indexes) and the domain-hierarchy conventions in docs/DATABASE.md.
//
// Scope is denormalised, exactly like Activity: `organization_id` and `plan_id` are
// copied from the (validated) endpoints by the service inside the create transaction —
// NEVER from client input. Invariant: `plan_id == predecessor.plan_id ==
// successor.plan_id` and `organization_id == predecessor.organization_id`. This powers
// the plan-level list, the single-query cycle-check edge load, and the plan-level
// cascade without a join.
//
// Two FKs point at `activities` (`predecessor_id`, `successor_id`) via explicitly
// named self-relations so Prisma can disambiguate the back-relations
// (Activity.predecessorLinks / Activity.successorLinks). Both are ON DELETE RESTRICT:
// links are never hard-deleted; soft-delete + endpoint-guarded restore is handled by
// the service layer (HierarchyLifecycleService, task A3), and RESTRICT guards against
// an accidental hard delete orphaning an edge.
model ActivityDependency {
  id             String @id @default(uuid(7)) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  planId         String @map("plan_id") @db.Uuid
  predecessorId  String @map("predecessor_id") @db.Uuid
  successorId    String @map("successor_id") @db.Uuid

  // Logic (Planner-owned). `lag_minutes` is a SIGNED working-MINUTE lag (negative = lead),
  // bounded to −5_256_000…5_256_000 (≈ ±10 years) by ck_dependencies_lag_minutes_range
  // (raw SQL). `lag_calendar` is the ADR-0036 §6 resolution seam — M1 lands the column
  // (default PROJECT_DEFAULT is behaviour-preserving), M3 wires the option. The public
  // API stays day-denominated (ADR-0036 §7); the service scales days↔minutes.
  type        DependencyType    @default(FS)
  lagMinutes  Int               @default(0) @map("lag_minutes")
  lagCalendar LagCalendarSource @default(PROJECT_DEFAULT) @map("lag_calendar")

  // CPM output — engine-owned (ADR-0022), recomputed each recalculate. True when this
  // edge is the binding tie that determines its successor's early start (a "driving"
  // logic relationship). Defaulted; NEVER accepted from a write DTO — written only by
  // the CPM engine's batched raw UPDATE, which touches engine columns alone (never
  // version/updated_at/updated_by), so a recalc is invisible to optimistic locking.
  // Reads false until the plan is first calculated.
  isDriving Boolean @default(false) @map("is_driving")

  // Housekeeping (as Activity): TEXT audit ids (Better Auth ids are TEXT — nullable),
  // optimistic-lock version, soft delete + restore-batch correlation.
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  predecessor  Activity     @relation("DependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Restrict)
  successor    Activity     @relation("DependencySuccessor", fields: [successorId], references: [id], onDelete: Restrict)

  // A given ordered pair may carry at most one link of each type among ACTIVE rows —
  // enforced by a PARTIAL unique index (uq_dependencies_pred_succ_type ON
  // (predecessor_id, successor_id, type) WHERE deleted_at IS NULL), raw SQL in the
  // migration (Prisma cannot express partial indexes). This allows the SS+FF overlap
  // "ladder" idiomatic to construction/linear scheduling while blocking exact
  // duplicates; a soft-deleted link frees its (pred, succ, type) triple for reuse.
  // It also backs the create DUPLICATE_DEPENDENCY (409) check.
  //
  // Direction indexes back the activity predecessors/successors lists AND the two FKs:
  // `predecessor_id` serves "successors of X" (edges out of X) and the cycle-walk
  // adjacency load; `successor_id` serves "predecessors of X". `(plan_id, created_at,
  // id)` covers the plan FK (leftmost prefix), the plan-level dependency list and its
  // cursor sort in one. `organization_id` is indexed on its own for its FK (RESTRICT)
  // and org-scoped IDOR loads. The partial delete_batch_id index (raw SQL, WHERE ...
  // IS NOT NULL) backs batch restore. A self-loop CHECK (predecessor_id <>
  // successor_id) and the lag-range CHECK are raw SQL in the migration.
  @@index([planId, createdAt, id])
  @@index([predecessorId])
  @@index([successorId])
  @@index([organizationId])
  @@map("dependencies")
}

// ---------------------------------------------------------------------------
// Working-day calendars — Calendar + CalendarException (M5, ADR-0024).
//
// A calendar fills the CPM engine's `WorkingDayCalendar` port (ADR-0023 §5) with
// a real working-week: a 7-bit weekday mask (`working_weekdays`, bit 0 = Monday …
// bit 6 = Sunday; must be non-zero) plus a sparse list of dated exceptions that
// flip a specific day's default (a holiday, or a worked weekend). Calendars are an
// org-scoped, reusable LIBRARY; a plan carries a nullable default calendar
// (`plans.calendar_id`, added in Task C1). The engine is unchanged — a pure
// factory (`buildWorkingDayCalendar`) builds the port impl from these rows.
//
// Both follow the house standards (UUID v7 PK, snake_case via @map, timestamptz
// UTC, NOT NULL by default, soft delete + `delete_batch_id`, audit, optimistic-
// locking `version`, scoped indexes) and the domain-hierarchy conventions in
// docs/DATABASE.md. Calendar's organization_id is NATIVE (the org is its direct
// parent, like Client); CalendarException's is DENORMALISED from its parent
// calendar (copied by the service, never client input — like Activity), so an
// org-scope/IDOR check and the cascade batch filter one indexed column.
// ---------------------------------------------------------------------------

model Calendar {
  id             String  @id @default(uuid(7)) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  description    String?

  // The weekly working pattern is the child `shifts` rows (ADR-0036 §2): per weekday a
  // sorted list of [start,end) minute windows (split shifts, 24h, midnight-crossing
  // nights). NO working-time guard lives here — a window-only calendar (all weekdays
  // empty; work comes only from positive exceptions) is VALID. "Has working time within
  // the horizon" is a cross-row/temporal property enforced at the engine factory + the
  // N11/N16 iteration cap (ADR-0036 §5), not a DB CHECK (the DAG-invariant precedent).

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  shifts       CalendarShift[]
  exceptions   CalendarException[]
  // Plans defaulting to this calendar (M5 Task C1). The service in-use guard counts
  // ACTIVE plans here before allowing a delete (409 CALENDAR_IN_USE); the FK is
  // RESTRICT as defence in depth.
  plans        Plan[]
  // Activities assigned this calendar (M5, ADR-0037). The delete-in-use guard now
  // ALSO counts ACTIVE activities here (WHERE deleted_at IS NULL) — a soft-deleted
  // activity must NOT block the delete; the FK is RESTRICT as defence in depth.
  activities   Activity[]
  // Resources whose OWN availability calendar this is (M7.1, ADR-0039). A resource
  // may reference an org calendar as its working-time; the CALENDAR_IN_USE delete
  // guard must therefore ALSO count ACTIVE resources here (WHERE deleted_at IS NULL),
  // alongside active plans + activities, before allowing a calendar delete (a service
  // follow-on when the resources module lands). FK is RESTRICT as defence in depth.
  resources    Resource[]

  // Calendar name is unique per organisation among ACTIVE rows — partial unique
  // (uq_calendars_org_name ON (organization_id, name) WHERE deleted_at IS NULL),
  // raw SQL in the migration (Prisma cannot express partial indexes). A soft-
  // deleted name is free to reuse. Backs the create DUPLICATE_CALENDAR (409) check.
  //
  // (organization_id, created_at, id) covers the organization_id FK (leftmost
  // prefix), the org-scoped active-list query AND its deterministic cursor sort
  // (ORDER BY created_at, id) — the same full-composite pattern as Client. It
  // subsumes a standalone organization_id index. The partial delete_batch_id index
  // (raw SQL, WHERE ... IS NOT NULL) backs batch restore.
  @@index([organizationId, createdAt, id])
  @@map("calendars")
}

// A dated override whose windows REPLACE the weekly pattern across an inclusive date
// range (ADR-0036 §2). A range with ZERO child windows is a holiday / non-work block
// (Christmas shutdown, a winter embargo); a range WITH windows is worked overtime or a
// window-only working period (a turnaround). Replaces the old whole-day `is_working`
// flag. An optional `label` names it for the editor.
model CalendarException {
  id             String @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent calendar (never client input). RESTRICT.
  organizationId String @map("organization_id") @db.Uuid
  calendarId     String @map("calendar_id") @db.Uuid

  // Inclusive `YYYY-MM-DD` range (single day ⇒ start == end). ck_calendar_exceptions_date_order
  // (end_date >= start_date) is raw SQL. Active-range non-overlap is a btree_gist EXCLUDE
  // (raw SQL) that REPLACES the old uq_calendar_exceptions_cal_date point-key partial unique.
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  label     String?

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  calendar     Calendar                  @relation(fields: [calendarId], references: [id], onDelete: Restrict)
  windows      CalendarExceptionWindow[]

  // (calendar_id, start_date) backs the FK (leftmost prefix), the editor's list-all load,
  // and the engine's active load ordered by start_date. organization_id indexed for its FK
  // + org-scoped IDOR. The partial delete_batch_id index (raw SQL) backs batch restore.
  @@index([calendarId, startDate])
  @@index([organizationId])
  @@map("calendar_exceptions")
}

// One [start_minute, end_minute) working window on one weekday of a calendar's weekly
// pattern (ADR-0036 §2). An OWNED VALUE ROW (the PlanLock precedent): no soft-delete, no
// version, no delete_batch_id, no audit ids, no denormalised organization_id — it is always
// reached VIA its (org-scoped) calendar and never queried/scoped on its own. The weekly
// pattern is edited as a SET (the service replaces the rows inside the calendar's write
// transaction; the calendar's own `version` provides the optimistic lock). FK ON DELETE
// CASCADE (true composition). Per-row bound/order CHECKs + a btree_gist EXCLUDE for
// non-overlap within (calendar, weekday) are raw SQL in the migration.
model CalendarShift {
  id          String @id @default(uuid(7)) @db.Uuid
  calendarId  String @map("calendar_id") @db.Uuid
  // Monday = 0 … Sunday = 6. Minutes from local midnight, [0, 1440] (1440 = 24:00;
  // midnight-crossing is two adjacent-day windows, never a wrap).
  weekday     Int    @map("weekday") @db.SmallInt
  startMinute Int    @map("start_minute") @db.SmallInt
  endMinute   Int    @map("end_minute") @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  calendar Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  // The engine load IS this index: WHERE calendar_id = ? ORDER BY weekday, start_minute.
  @@index([calendarId, weekday, startMinute])
  @@map("calendar_shifts")
}

// One [start_minute, end_minute) working window inside a CalendarException's replacement
// set (ADR-0036 §2). Same OWNED-VALUE-ROW treatment as CalendarShift; a holiday exception
// simply has zero of these rows. FK ON DELETE CASCADE.
model CalendarExceptionWindow {
  id                  String @id @default(uuid(7)) @db.Uuid
  calendarExceptionId String @map("calendar_exception_id") @db.Uuid
  startMinute         Int    @map("start_minute") @db.SmallInt
  endMinute           Int    @map("end_minute") @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  exception CalendarException @relation(fields: [calendarExceptionId], references: [id], onDelete: Cascade)

  // Engine load IS this index: WHERE calendar_exception_id = ? ORDER BY start_minute.
  @@index([calendarExceptionId, startMinute])
  @@map("calendar_exception_windows")
}

// ---------------------------------------------------------------------------
// Baselines — Baseline + BaselineActivity (M7, ADR-0025).
//
// A Baseline is a named, frozen snapshot of a plan's schedule — the "plan of
// record" a planner compares the live schedule against (PROJECT_BRIEF §8/§11,
// Journey 4). At most ONE baseline per plan is active at a time (the comparison
// baseline); this is guaranteed by a DB partial unique, not just code.
//
// The snapshot is a self-contained COPY, not a reference (ADR-0025, Q1):
// BaselineActivity duplicates each activity's identity + computed CPM dates, and
// `source_activity_id` is a PLAIN correlation UUID with NO foreign key — so a
// baseline survives the source activities' 90-day hard purge (PROJECT_BRIEF §13)
// and stays a faithful historical record even if a live activity is edited or
// deleted. Variance (live vs active baseline) is computed server-side in working
// days on the plan's calendar (ADR-0024) — the baseline stores raw dates only.
//
// Both follow every house standard (UUID v7 PK, snake_case via @map, timestamptz
// UTC, NOT NULL by default, soft delete + `delete_batch_id`, TEXT audit ids,
// optimistic-locking `version`, scoped indexes) and the domain-hierarchy
// conventions in docs/DATABASE.md. Baseline's organization_id is DENORMALISED from
// its plan; BaselineActivity's from its parent baseline (copied by the service,
// never client input — like Activity). There is no DB cascade: a baseline and its
// snapshot rows soft-delete together under one `delete_batch_id`, and a
// plan/project/client delete cascades to contained baselines the same way (the
// HierarchyLifecycleService pattern).
// ---------------------------------------------------------------------------

model Baseline {
  id             String  @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent plan (never client input). RESTRICT.
  organizationId String  @map("organization_id") @db.Uuid
  planId         String  @map("plan_id") @db.Uuid
  name           String
  // At most one active baseline per plan — the comparison baseline. Enforced by a
  // PARTIAL unique (uq_baselines_plan_active ON (plan_id) WHERE is_active = true AND
  // deleted_at IS NULL), raw SQL in the migration; the service flips it atomically
  // under the plan write-lock. The plan's FIRST baseline is captured active.
  isActive       Boolean @default(false) @map("is_active")

  // Small denormalisations captured at freeze time so the list panel renders without
  // loading snapshot rows. `captured_at` is the as-of instant; `data_date` is the
  // plan's plannedStart at capture; `captured_project_finish` is the plan's latest
  // inclusive finish at capture (both date-only, like the CPM columns, ADR-0023).
  capturedAt            DateTime  @default(now()) @map("captured_at") @db.Timestamptz(3)
  dataDate              DateTime? @map("data_date") @db.Date
  capturedProjectFinish DateTime? @map("captured_project_finish") @db.Date

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  activities   BaselineActivity[]

  // Baseline name is unique per PLAN among ACTIVE rows — partial unique
  // (uq_baselines_plan_name ON (plan_id, name) WHERE deleted_at IS NULL), raw SQL in
  // the migration. Backs the capture DUPLICATE_BASELINE (409) check; a soft-deleted
  // name is free to reuse.
  //
  // (plan_id, created_at, id) covers the plan FK (leftmost prefix), the
  // list-baselines-for-a-plan query and its deterministic cursor sort in one.
  // organization_id is indexed on its own for its FK (RESTRICT) and org-scoped IDOR
  // loads. The partial delete_batch_id index (raw SQL) backs batch restore.
  @@index([planId, createdAt, id])
  @@index([organizationId])
  @@map("baselines")
}

// A BaselineActivity — one activity's frozen snapshot inside a baseline. A
// self-contained copy (ADR-0025): it duplicates the activity's identity and its
// captured CPM dates, and `source_activity_id` is a PLAIN correlation UUID (NO FK)
// so the snapshot outlives edits/deletes/hard-purge of the live activity. Rows are
// immutable after capture; they carry the full housekeeping set (matching
// CalendarException) and soft-delete with their parent baseline under one
// `delete_batch_id`.
model BaselineActivity {
  id               String @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent baseline (never client input). RESTRICT.
  organizationId   String @map("organization_id") @db.Uuid
  baselineId       String @map("baseline_id") @db.Uuid
  // The activity this row was snapshotted from — a plain correlation id, NOT a
  // foreign key (ADR-0025): the snapshot must survive the source activity's 90-day
  // hard purge and stay faithful even if it is edited/deleted. Joined against live
  // activities (on this id) to compute variance.
  sourceActivityId String @map("source_activity_id") @db.Uuid

  // Frozen identity (as captured).
  code            String?
  name            String
  type            ActivityType @default(TASK)
  // Frozen working-MINUTES (ADR-0036) so a historic baseline stays faithful (ADR-0025).
  durationMinutes Int          @map("duration_minutes")

  // Frozen schedule (the captured CPM output, all date-only like the Activity
  // columns, ADR-0023). `baseline_start`/`baseline_finish` are the captured
  // early start/finish; `total_float` is unconstrained (negative float is valid).
  baselineStart  DateTime? @map("baseline_start") @db.Date
  baselineFinish DateTime? @map("baseline_finish") @db.Date
  lateStart      DateTime? @map("late_start") @db.Date
  lateFinish     DateTime? @map("late_finish") @db.Date
  totalFloat     Int?      @map("total_float")
  isCritical     Boolean   @default(false) @map("is_critical")

  // The captured COST BASELINE — the activity's budgeted cost frozen at capture (EV1,
  // ADR-0042; the ADR-0025 snapshot amendment), giving the active baseline a committed PV /
  // BCWS reference. BIGINT minor units in the plan's currency. NULLABLE / NO default ⇒ a
  // baseline captured BEFORE this rung reads NULL (PV falls back to the live budget and the
  // EV read flags `costBaselineMissing`, never an error). Immutable after capture like every
  // snapshot column. ck_baseline_activities_budgeted_cost_nonneg (nullable-safe `>= 0`) is
  // defence-in-depth (N22 family). No index (the snapshot is loaded whole per baseline).
  // DARK until EV2 reads it.
  budgetedCost BigInt? @map("budgeted_cost")

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  baseline     Baseline     @relation(fields: [baselineId], references: [id], onDelete: Restrict)

  // (baseline_id, source_activity_id) is the variance join key AND covers the
  // baseline_id FK / load-all-rows-for-a-baseline (leftmost prefix), so no separate
  // baseline_id index is needed. organization_id is indexed on its own for its FK
  // (RESTRICT) and org-scoped IDOR loads. The partial delete_batch_id index (raw SQL)
  // backs batch restore alongside the parent baseline.
  @@index([baselineId, sourceActivityId])
  @@index([organizationId])
  @@map("baseline_activities")
}

// ---------------------------------------------------------------------------
// PlanLock — the single-editor edit-lock lease (ADR-0028).
//
// A deliberately SPARSE, ephemeral coordination row: PRESENCE = a Planner holds
// the pen, ABSENCE = the plan is free. It is NOT a domain record and so breaks
// from the hierarchy template on purpose — no soft delete, no `version`, no
// `created_by`/`updated_by`, no `delete_batch_id`. It intentionally does NOT live
// on `Plan`: frequent heartbeat writes must not touch `Plan.version`/`updated_at`
// (they would masquerade as plan edits and collide with plan-metadata optimistic
// locking — the same derived-vs-edited separation as ADR-0022's engine columns).
//
//   - PK IS `plan_id` (not a UUID v7 `id`) — this is the one-lock-per-plan
//     invariant made physical: at most one row can exist per plan.
//   - The `plan` FK is ON DELETE CASCADE — unlike every other child table's
//     RESTRICT. Those are RESTRICT because they are soft-deleted domain records we
//     must never let an accidental hard delete orphan. A lock is the opposite:
//     transient state wholly OWNED/COMPOSED by its plan (DATABASE.md: "CASCADE only
//     for true ownership/composition"), with nothing to preserve. Plans are
//     soft-deleted in normal operation (the FK never fires; a stale lock is
//     harmless and expires by TTL), so CASCADE only matters on a rare compliance
//     HARD purge — where the lock must vanish with the plan and must never BLOCK
//     the purge. Mirrors the Session/Account → User CASCADE precedent for
//     library-managed ephemeral rows.
//   - `organization_id` is denormalised from the plan (copied by the service inside
//     the acquire transaction, NEVER from client input; invariant:
//     lock.organization_id == plan.organization_id) as the tenant scope tag for
//     scoped reads/audit. Its FK is RESTRICT to match every other denormalised-org
//     table; in practice it is inert (plan → org is RESTRICT, so it fires first).
//   - `holder_user_id` / `requested_by_user_id` are plain TEXT with NO FK — Better
//     Auth ids are opaque TEXT (not UUID), and these are attribution stamps, so they
//     follow the `created_by`/`updated_by`/`accepted_by_user_id` convention, NOT the
//     structural OrgMember.user_id membership FK.
//   - `requested_by_user_id` / `requested_at` hold at most one PENDING peer
//     request-control (newest wins, Q-A). Cleared by the service on every holder
//     change (acquire / take-over / release / hand-off) so a stale request never
//     carries across a hand-off; "grace elapsed" is a pure `now() - requested_at`
//     comparison — nothing to schedule or sweep.
//   - An expired row (`expires_at < now()`) reads as free and is overwritten on the
//     next acquire — no sweeper in v1.
// ---------------------------------------------------------------------------
model PlanLock {
  // PK IS the plan id ⇒ one lock per plan (the invariant). No separate UUID v7 id.
  planId         String @id @map("plan_id") @db.Uuid
  // Denormalised tenant scope tag, copied from the plan (never client input).
  organizationId String @map("organization_id") @db.Uuid
  // Better Auth id = opaque TEXT (not UUID); attribution stamp, no FK (see header).
  holderUserId   String @map("holder_user_id")

  // The lease. `expires_at` = `heartbeat_at` + TTL; expiry is evaluated server-side
  // against now(). All are instants → timestamptz UTC (not @db.Date).
  acquiredAt  DateTime @map("acquired_at") @db.Timestamptz(3)
  heartbeatAt DateTime @map("heartbeat_at") @db.Timestamptz(3)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(3)

  // Pending peer request-control (Q-A). Both null = no pending request. TEXT id, no FK.
  requestedByUserId String?   @map("requested_by_user_id")
  requestedAt       DateTime? @map("requested_at") @db.Timestamptz(3)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  // plan FK is CASCADE (ephemeral composition); org FK is RESTRICT (scope tag,
  // matches every sibling; inert because plan → org RESTRICT fires first).
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)

  // The only non-PK index. Status read and heartbeat are single-row PK lookups on
  // plan_id (the heartbeat's extra `holder_user_id` / `expires_at > now()` predicates
  // filter the ONE PK-selected row for free — no index warranted, and one on a
  // low-selectivity/volatile column would only cost writes). This index backs the
  // organization_id FK and any org-scoped audit read of held locks.
  @@index([organizationId])
  @@map("plan_locks")
}

// ---------------------------------------------------------------------------
// Resources — Resource + ResourceAssignment (M7.1, ADR-0039).
//
// The resource dimension the CPM engine schedules around. A Resource is an
// org-scoped, reusable LIBRARY entity — a crew, a plant item, a material — modelled
// exactly like Calendar (a sibling of the Client→Project→Plan tree, NOT a hierarchy
// level). A ResourceAssignment ties a Resource to an Activity with a budgeted
// quantity and, for at most one assignment per activity, the `is_driving` flag that
// designates the resource whose calendar governs a RESOURCE_DEPENDENT activity
// (ADR-0035 §23, wired in M7.2). This slice is the MODEL only — an assignment is
// reference data until an activity is made resource-dependent, so with no resources
// the schedule is byte-identical (the parity gate).
//
// Both follow every house standard (UUID v7 PK, snake_case via @map, timestamptz
// UTC, NOT NULL by default, soft delete + delete_batch_id, TEXT audit ids,
// optimistic-locking `version`, scoped indexes) and the domain conventions in
// docs/DATABASE.md. Resource.organization_id is NATIVE (the org is its direct parent,
// like Calendar / Client); ResourceAssignment.organization_id is DENORMALISED from
// its endpoints (copied by the service inside the create transaction, NEVER client
// input — the Activity / ActivityDependency pattern), so an org-scope/IDOR check and
// the cascade batch filter one indexed column without a join.
//
// DELIBERATELY LEAN (ADR-0039): a kind, an optional own Calendar, and a budgeted
// quantity are all rung-1 needs. Availability (max units), cost, and earned-value
// columns are RESERVED for their later rungs (levelling / cost / EV), added only when
// those rungs land — mirroring how activities.calendar_id was reserved (ADR-0024).
// ---------------------------------------------------------------------------

model Resource {
  id              String       @id @default(uuid(7)) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  name            String
  // Optional short human handle (e.g. "CR600", "CREW-A"). Unique per org among ACTIVE
  // rows where set — a partial unique uq_resources_org_code (WHERE deleted_at IS NULL
  // AND code IS NOT NULL), raw SQL in the migration; NULL codes are exempt. Mirrors
  // activities.code / uq_activities_plan_code — a natural-key handle (docs/DATABASE.md:
  // unique constraints for natural keys).
  code            String?
  description     String?
  kind            ResourceKind
  // The resource's OWN working-time calendar (ADR-0039; the ADR-0037 port seam rung 2
  // rides). Nullable → the resource inherits the plan calendar at schedule time (the
  // driving-calendar fallback order: driving-resource calendar → activity calendar →
  // plan default). Client-settable, but the FK alone does NOT enforce same-org — a
  // cross-org calendarId satisfies it — so the org-scope check stays in the service
  // (like the plan / activity calendar picker, ADR-0037). FK is RESTRICT (calendars
  // soft-delete only; the CALENDAR_IN_USE guard — extended to count active resources
  // too — is the real protection, RESTRICT is defence in depth). Backed by the partial
  // idx_resources_calendar_id (WHERE deleted_at IS NULL AND calendar_id IS NOT NULL).
  calendarId      String?      @map("calendar_id") @db.Uuid
  // The per-resource CAPACITY ceiling — the max units of work this resource can supply
  // per working hour (ADR-0041 §2, activating the column ADR-0039 RESERVED "for
  // levelling"). An EXACT numeric (DECIMAL(18,4)) like the assignment quantities.
  // NULLABLE with NO default — NULL = UNCAPPED, the parity-preserving default: an
  // uncapped resource is never over-allocated, so the levelling pass has nothing to
  // resolve and the default recalc stays byte-identical (never add a DEFAULT — a
  // DEFAULT 0 would mean "zero capacity" and silently over-allocate every existing
  // resource). Client-settable (a Planner sets the hire ceiling). `max_units_per_hour
  // IS NULL OR >= 0` is enforced by ck_resources_max_units_per_hour_nonneg (raw SQL —
  // nullable-safe), the DB backstop behind the DTO @Min(0) boundary reject (N21,
  // ADR-0035 §25), mirroring resource_assignments.budgeted_units/units_per_hour
  // (N14/N19). No index: read only on the full-plan recalc demand load, never a query
  // predicate. MUST stay in lock-step with @repo/types. LEVELLING-READ ONLY when the
  // plan opts in (plans.level_resources); dark until L2 wires the pass.
  maxUnitsPerHour Decimal?     @map("max_units_per_hour") @db.Decimal(18, 4)
  // The resource's planned COST RATE (EV1, ADR-0042; activating the column ADR-0039 RESERVED
  // "for the cost rung"). A RATE COEFFICIENT, so DECIMAL(18,4) like the sibling rates
  // `max_units_per_hour` / `units_per_hour` (NOT a stored money amount — those stay BIGINT
  // minor units): the house rule is "rate coefficients are Decimal(18,4); stored money amounts
  // are integer minor units". Decimal keeps a composite rate (e.g. £52.3750/unit) exact rather
  // than rounding it to a whole minor unit before multiplying, so the single rounding point is
  // the derived amount. Expressed in MINOR UNITS per unit of work (e.g. 5237.5000 pence/unit),
  // so a derived assignment budget is `round(budgeted_units × cost_per_unit)` minor units — no
  // major/minor conversion. COST-PER-UNIT (P6 "Price/Unit"), NOT cost-per-hour: it multiplies
  // the assignment's `budgeted_units` directly, aligned with the units backbone (ADR-0040)
  // rather than re-deriving hours. NULLABLE with NO default — NULL = no cost (the resource
  // contributes ZERO to BAC/AC), the parity-preserving default (a DEFAULT is omitted to keep
  // "no rate set" explicit). Client-settable. ck_resources_cost_per_unit_nonneg (nullable-safe
  // `>= 0`) is the DB backstop behind the DTO @Min(0) reject (N22), mirroring
  // max_units_per_hour/N21. No index: read only on the plan-scoped EV assignment/rate load,
  // never a query predicate. MUST stay in lock-step with @repo/types. DARK until EV2 reads it.
  costPerUnit     Decimal?     @map("cost_per_unit") @db.Decimal(18, 4)

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  calendar     Calendar?            @relation(fields: [calendarId], references: [id], onDelete: Restrict)
  assignments  ResourceAssignment[]

  // Resource name is unique per org among ACTIVE rows — partial unique
  // (uq_resources_org_name ON (organization_id, name) WHERE deleted_at IS NULL), raw
  // SQL in the migration (Prisma cannot express partial indexes). Backs the create
  // DUPLICATE_RESOURCE (409) check; a soft-deleted name is free to reuse.
  //
  // (organization_id, created_at, id) covers the organization_id FK (leftmost prefix),
  // the org-scoped active-list query AND its deterministic cursor sort — the same
  // full-composite pattern as Calendar / Client; it subsumes a standalone org index.
  // The partial idx_resources_calendar_id (the CALENDAR_IN_USE / driving-calendar load)
  // and idx_resources_delete_batch_id (batch restore) are raw SQL in the migration.
  @@index([organizationId, createdAt, id])
  @@map("resources")
}

model ResourceAssignment {
  id             String @id @default(uuid(7)) @db.Uuid
  // Denormalised from the endpoints (copied by the service inside the create
  // transaction, NEVER client input; invariant: organization_id ==
  // activity.organization_id == resource.organization_id — service-enforced, the FK
  // scopes only to `organizations`). RESTRICT.
  organizationId String @map("organization_id") @db.Uuid
  activityId     String @map("activity_id") @db.Uuid
  resourceId     String @map("resource_id") @db.Uuid

  // The assigned quantity of work. An EXACT numeric (docs/DATABASE.md: exact data uses
  // exact types) — the schema's first Decimal. `>= 0` is enforced by
  // ck_resource_assignments_budgeted_units_nonneg (raw SQL), the DB backstop behind the
  // DTO @Min(0) boundary reject (N14, ADR-0035 §25) so a bypass can never persist a
  // negative. Defaulted 0 for a defensive direct-DB insert; the service always sets it.
  budgetedUnits Decimal           @default(0) @map("budgeted_units") @db.Decimal(18, 4)
  // The planned RATE (units of work per working hour) at which the driving resource
  // produces on THIS activity — the `Units/Time` of the P6 triad (M7 rung 4, ADR-0040).
  // An EXACT numeric like budgeted_units (DECIMAL(18,4)). NULLABLE with NO default — a
  // NULL rate means the triad is INERT (nothing to recompute; `duration_minutes` stays as
  // entered), the parity gate: with no units_per_hour on any driving assignment the
  // recalc is byte-identical (never add a DEFAULT — that would silently activate the
  // triad on every existing row). Client-settable. `units_per_hour IS NULL OR >= 0` is
  // enforced by ck_resource_assignments_units_per_hour_nonneg (raw SQL — nullable-safe),
  // the DB backstop behind the DTO @Min(0) boundary reject (N19), mirroring
  // budgeted_units/N14. Only the DRIVING assignment (is_driving) participates in the
  // triad; a zero rate on a units-driven recompute is a service reject (N20 — a CHECK
  // cannot read the activity's duration_type). MUST stay in lock-step with @repo/types.
  unitsPerHour  Decimal?          @map("units_per_hour") @db.Decimal(18, 4)
  // Designates THE driving resource of a RESOURCE_DEPENDENT activity (ADR-0035 §23): its
  // resolved calendar governs the activity's scheduling (wired in M7.2). At most ONE
  // driving assignment per activity is guaranteed in the DB by the partial unique
  // uq_resource_assignments_activity_driving (activity_id) WHERE is_driving AND
  // deleted_at IS NULL (raw SQL). "EXACTLY one on a resource-dependent activity" and "a
  // MATERIAL resource may not drive" are SERVICE invariants (a partial-unique/FK cannot
  // read the activity's type or the resource's kind).
  isDriving     Boolean           @default(false) @map("is_driving")
  // Resource loading curve (M7 rung 5, ADR-0044 §3 / ADR-0035 §31). CLIENT-SETTABLE: the
  // named P6 profile the resource-histogram read-model distributes this assignment's
  // `budgeted_units` by across the activity duration (span = duration − assignment lag),
  // conserving units. It shapes the histogram (and can feed cost time-phasing), moves NO
  // date, and does NOT feed the levelling pass this rung (Q2) — a pure read-model, so the
  // parity gate is trivial. Constant DEFAULT UNIFORM = flat load = today's byte-identical
  // histogram (never add a non-constant default — it would re-shape every existing
  // assignment). The 21-point profile constants live in the read-model, not the DB. No
  // index: read only on the plan-scoped histogram/EV assignment load, never a query
  // predicate (the is_driving / percent_complete_type precedent — a low-cardinality enum
  // read with the whole plan's assignments, never filtered across plans). MUST stay in
  // lock-step with the `ResourceCurveType` union in @repo/types.
  curveType     ResourceCurveType @default(UNIFORM) @map("curve_type")

  // Earned Value cost inputs (EV1, ADR-0042). Money is BIGINT minor units in the plan's
  // `currency_code`; `actual_units` is an exact-numeric QUANTITY like `budgeted_units`.
  //   * budgeted_cost — an OPTIONAL definition OVERRIDE of the derived budgeted cost.
  //     NULLABLE / NO default ⇒ NULL = DERIVE at read time (`budgeted_units ×
  //     resource.cost_per_unit`, Q1); a non-null value pins an explicit budget (e.g. a quoted
  //     sub-contract price that is not units × rate). The derive-when-null pattern keeps the
  //     common case input-free while allowing an override — the ADR-0040 rate-on-the-
  //     assignment precedent.
  //   * actual_cost — CONTRIBUTOR progress: the cost actually spent on this assignment,
  //     entered directly (Q8 — construction actuals come from the cost system, not units).
  //     NOT NULL DEFAULT 0 (0 = nothing spent yet, a real value with no unset/zero ambiguity),
  //     metadata-only backfill, mirroring `budgeted_units @default(0)`.
  //   * actual_units — CONTRIBUTOR progress: the quantity of work actually done, feeding the
  //     UNITS performance % (`actual_units / budgeted_units`). DECIMAL(18,4) NOT NULL DEFAULT
  //     0, mirroring `budgeted_units`.
  // ck_resource_assignments_budgeted_cost_nonneg (nullable-safe), _actual_cost_nonneg, and
  // _actual_units_nonneg (`>= 0`) are the DB backstops behind the DTO @Min(0) rejects (N22
  // for the money pair; the units N14 precedent for actual_units). No index: read only on the
  // plan-scoped EV assignment load. MUST stay in lock-step with @repo/types. DARK until EV2.
  budgetedCost BigInt? @map("budgeted_cost")
  actualCost   BigInt  @default(0) @map("actual_cost")
  actualUnits  Decimal @default(0) @map("actual_units") @db.Decimal(18, 4)

  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  activity     Activity     @relation(fields: [activityId], references: [id], onDelete: Restrict)
  resource     Resource     @relation(fields: [resourceId], references: [id], onDelete: Restrict)

  // Uniqueness & FK-backing indexes are PARTIAL (raw SQL — Prisma cannot express a
  // WHERE), following the calendar_id / parent_id precedent (assignments soft-delete
  // only, so the FK RESTRICT check never fires; the real access is active-row lookups):
  //   * uq_resource_assignments_activity_resource (activity_id, resource_id) WHERE
  //     deleted_at IS NULL — one ACTIVE assignment per (activity, resource); backs
  //     DUPLICATE_ASSIGNMENT (409). Its leftmost prefix (activity_id) ALSO subsumes a
  //     standalone active-activity_id index (the "load an activity's assignments" load),
  //     so none is added.
  //   * uq_resource_assignments_activity_driving (activity_id) WHERE is_driving AND
  //     deleted_at IS NULL — the ≤1-driver-per-activity backstop AND the recalc
  //     "find THE driving assignment of this activity" load.
  //   * idx_resource_assignments_resource_id (resource_id) WHERE deleted_at IS NULL —
  //     the RESOURCE_IN_USE delete guard's active-assignment count.
  //   * idx_resource_assignments_delete_batch_id — batch restore (WHERE ... IS NOT NULL).
  // organization_id is a FULL index (backs its FK RESTRICT + org-scoped IDOR loads),
  // like every denormalised-org sibling.
  @@index([organizationId])
  @@map("resource_assignments")
}

// ---------------------------------------------------------------------------
// ActivityStep — the weighted-checklist step (M7 rung 5, ADR-0044 §2 / ADR-0035 §33).
//
// A per-activity checklist row (`seq`, `name`, `weight`, `percent_complete`). When an
// activity has steps, its PHYSICAL %-complete rolls up as the weighted mean
// Σ(wᵢ·pᵢ)/Σ(wᵢ) and WINS over the manual `physical_percent_complete`; with no steps the
// manual field behaves exactly as today (ADR-0042 parity). Steps feed the PHYSICAL
// Earned-Value measure ONLY — no engine change, no CPM date moves. All-zero weights ⇒ the
// N27 fallback to the manual physical % (never a divide-by-zero, never a reject).
//
// A full reference-template child, modelled exactly like CalendarException /
// ResourceAssignment: UUID v7 PK, snake_case via @map, timestamptz UTC, NOT NULL by
// default, soft delete + delete_batch_id, TEXT audit ids, optimistic-locking `version`,
// scoped indexes. organization_id is DENORMALISED from the parent activity (copied by the
// service inside the create transaction, NEVER client input — the Activity /
// ResourceAssignment pattern), so an org-scope/IDOR check and the cascade batch filter one
// indexed column without a join.
//
// Soft-delete cascade is SERVICE-owned (no DB cascade): soft-deleting an activity SHOULD
// sweep its active steps under the SAME delete_batch_id (the assignment / incident-edge
// precedent in HierarchyLifecycleService) — a lifecycle follow-on for the F2 build, not
// this schema slice. The FK is RESTRICT (steps soft-delete only; the referential check
// never fires — defence in depth).
// ---------------------------------------------------------------------------

model ActivityStep {
  id             String @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent activity (never client input). RESTRICT.
  organizationId String @map("organization_id") @db.Uuid
  activityId     String @map("activity_id") @db.Uuid

  // Ordering within the activity's checklist. The service assigns/validates a contiguous
  // `seq` on bulk-replace; at most one ACTIVE step per (activity, seq) is guaranteed by
  // the partial unique uq_activity_steps_activity_seq (raw SQL, WHERE deleted_at IS NULL).
  seq             Int
  name            String
  // The step's relative weight in the weighted-mean physical %. An EXACT numeric
  // (DECIMAL(18,4)) mirroring resource_assignments.budgeted_units exactly — physical
  // quantities use exact types, and (18,4) is the schema's established quantity precision.
  // ck_activity_steps_weight_nonneg (`>= 0`, raw SQL) is the DB backstop (weights are
  // non-negative; all-zero ⇒ N27 fallback, still not a negative). Defaulted 0 for a
  // defensive direct-DB insert; the service always sets it (the budgeted_units precedent).
  weight          Decimal @default(0) @db.Decimal(18, 4)
  // The step's own completion, SMALLINT 0–100 (mirrors physical_percent_complete's type).
  // NOT NULL DEFAULT 0 (a step always has a percent; a new step is 0% done — unlike the
  // NULLABLE activity-level physical_percent_complete, an "unset" step-percent is
  // meaningless). ck_activity_steps_percent_complete_range (0–100, raw SQL) is the N28 DB
  // backstop behind the DTO 422 STEP_PERCENT_OUT_OF_RANGE reject, mirroring
  // ck_activities_physical_percent_complete_range (but NOT nullable-safe — always set).
  percentComplete Int     @default(0) @map("percent_complete") @db.SmallInt

  // Housekeeping (as ResourceAssignment): TEXT audit ids, optimistic-lock version, soft
  // delete + restore-batch correlation.
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  activity     Activity     @relation(fields: [activityId], references: [id], onDelete: Restrict)

  // organization_id is a FULL index (backs its FK RESTRICT + org-scoped IDOR loads), like
  // every denormalised-org sibling. There is deliberately NO standalone activity_id index:
  // the partial unique uq_activity_steps_activity_seq (activity_id, seq) WHERE deleted_at IS
  // NULL (raw SQL) has activity_id as its leftmost prefix, so it already serves the "load an
  // activity's ACTIVE steps ordered by seq" query — and the index is pre-sorted by seq — the
  // exact uq_resource_assignments_activity_resource precedent (activity_id prefix subsumes the
  // assignment-list index). The FK RESTRICT referential check would need an all-rows index,
  // but steps soft-delete only so it never fires (the service sweep is the real path). The
  // partial idx_activity_steps_delete_batch_id (raw SQL, WHERE ... IS NOT NULL) backs batch
  // restore.
  @@index([organizationId])
  @@map("activity_steps")
}
