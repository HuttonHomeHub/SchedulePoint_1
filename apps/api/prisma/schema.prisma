// Prisma schema for the Blank App API.
// Docs: https://www.prisma.io/docs
//
// Conventions: see docs/DATABASE.md. Columns are snake_case in the database
// (via @map/@@map) while Prisma fields stay camelCase. Timestamps are
// timestamptz (UTC). Primary keys are UUID v7 (time-ordered). Every table
// carries created_at/updated_at; mutable rows carry a soft-delete (deleted_at)
// and an optimistic-locking version.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// No domain models yet — the real application starts from a clean schema.
// The first feature adds the first model and the first migration
// (`prisma migrate dev`). Use the reference-feature template in
// `apps/api/examples/reference-feature/` as the pattern to copy
// (see docs/REFERENCE_FEATURE.md).
// ---------------------------------------------------------------------------
