// Prisma schema for the Blank App API.
// Docs: https://www.prisma.io/docs
//
// Conventions: see docs/DATABASE.md. Columns are snake_case in the database
// (via @map/@@map) while Prisma fields stay camelCase. Timestamps are
// timestamptz (UTC). Primary keys are UUID v7 (time-ordered). Every table
// carries created_at/updated_at; mutable rows carry a soft-delete (deleted_at)
// and an optimistic-locking version.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity (Better Auth) — ADR-0003, ADR-0016.
//
// These four tables are owned by Better Auth (the authentication provider) and
// must keep the field names it expects; @map keeps the DB columns snake_case
// and the tables plural per docs/DATABASE.md. Their primary keys are the opaque
// string ids Better Auth generates (a deliberate, documented exception to the
// UUID-v7 default: these rows are library-managed, not domain rows). `User` is
// modelled here — not hidden inside the auth library — so future domain tables
// (OrgMember, Invitation, …) can foreign-key to it and be organisation-scoped.
// ---------------------------------------------------------------------------

model User {
  id            String      @id
  name          String
  email         String      @unique
  emailVerified Boolean     @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions      Session[]
  accounts      Account[]
  memberships   OrgMember[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([identifier])
  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Tenancy foundation — Organization & OrgMember (ADR-0016).
//
// These are the canonical organisation-scoping models the whole product builds
// on. `OrgMember` is the single source of truth for "which user is in which
// organisation, with what role" — the scoping key every future feature's
// `principal.can(permission, organizationId)` check resolves against. Follows
// docs/DATABASE.md: UUID v7 PKs, snake_case columns via @map, timestamptz UTC,
// soft delete, audit columns, optimistic-locking `version`, scoped indexes.
// ---------------------------------------------------------------------------

// Organisation-scoped roles, least → most privileged. MUST stay in lock-step
// with the TypeScript `OrganizationRole` enum in
// apps/api/src/common/auth/principal.ts (ADR-0016). `EXTERNAL_GUEST` is
// deliberately NOT a member role (it is a per-plan share grant, modelled
// separately in a future ADR).
enum OrganizationRole {
  VIEWER
  CONTRIBUTOR
  PLANNER
  ORG_ADMIN
}

model Organization {
  id          String       @id @default(uuid(7)) @db.Uuid
  name        String
  // URL-safe, unique per deployment, immutable in v1. Uniqueness is enforced by
  // a PARTIAL unique index that ignores soft-deleted rows (uq_organizations_slug
  // WHERE deleted_at IS NULL) — Prisma cannot express partial indexes, so it is
  // added as raw SQL in the migration. This index also serves slug lookups
  // (which always filter deleted_at IS NULL), so no separate @@index is needed.
  slug        String
  version     Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy   String?      @map("created_by")
  updatedBy   String?      @map("updated_by")
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(3)
  members     OrgMember[]
  invitations Invitation[]
  // Domain hierarchy owned by this organisation. Project/Plan back-relations
  // exist because those tables carry a denormalised organization_id FK (see the
  // Client/Project/Plan models below), not because the org is their direct
  // parent — the tree is Organization → Client → Project → Plan.
  clients     Client[]
  projects    Project[]
  plans       Plan[]
  activities  Activity[]

  @@map("organizations")
}

model OrgMember {
  id             String           @id @default(uuid(7)) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  // FK → users.id. Better Auth generates opaque TEXT ids (NOT UUIDs), so this
  // column is plain `String` with NO @db.Uuid — it must match the TEXT PK it
  // references, otherwise the FK/migration fails.
  userId         String           @map("user_id")
  role           OrganizationRole
  version        Int              @default(1)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?          @map("created_by")
  updatedBy      String?          @map("updated_by")
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)

  // A user is an active member of an org at most once → enforced by a PARTIAL
  // unique index (uq_org_members_org_user ON (organization_id, user_id) WHERE
  // deleted_at IS NULL), added as raw SQL in the migration (Prisma cannot
  // express partial indexes). Re-adding a soft-deleted member is therefore
  // allowed.
  //
  // (organization_id, role) serves both "list an org's members" (leftmost
  // prefix on organization_id, also covering the FK) and the last-Org-Admin
  // count invariant; it subsumes a standalone organization_id index.
  @@index([organizationId, role])
  @@index([userId])
  @@map("org_members")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// An invitation to join an organisation with a role (ADR-0016). The raw token is
// never stored — only its hash (defence in depth); the raw value is returned once
// on create and emailed via the MailService port. A partial unique index keeps at
// most one PENDING invite per (organisation, email); expiry + status gate accept.
model Invitation {
  id               String           @id @default(uuid(7)) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  email            String
  role             OrganizationRole
  tokenHash        String           @unique @map("token_hash")
  status           InvitationStatus @default(PENDING)
  expiresAt        DateTime         @map("expires_at") @db.Timestamptz(3)
  acceptedByUserId String?          @map("accepted_by_user_id")
  acceptedAt       DateTime?        @map("accepted_at") @db.Timestamptz(3)
  version          Int              @default(1)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy        String?          @map("created_by")
  updatedBy        String?          @map("updated_by")
  deletedAt        DateTime?        @map("deleted_at") @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@map("invitations")
}

// ---------------------------------------------------------------------------
// Domain hierarchy — Client → Project → Plan (feature: hierarchy CRUD).
//
// The three organisation-scoped container levels every scheduling feature hangs
// off: an org owns Clients, a Client owns Projects, a Project owns Plans (a Plan
// is the future host of Activities and the TSLD canvas). All follow the same
// house standards as the tenancy models above: UUID v7 PKs, snake_case columns
// via @map, timestamptz UTC, NOT NULL by default, soft delete, audit columns,
// optimistic-locking `version`, and scoped indexes. See docs/DATABASE.md.
//
// Two cross-cutting conventions (recorded in docs/DECISIONS.md) apply here:
//
//   1. Denormalised `organization_id`. Project and Plan carry organization_id
//      directly (copied from their parent by the service layer inside the create
//      transaction, NEVER from client input) in addition to their parent FK, so
//      every scope/IDOR check and org-scoped query filters one indexed column
//      without a 2–3 table join. Invariant: a child's organization_id always
//      equals its parent's. Client's organization_id is native (the org is its
//      direct parent), not denormalised.
//
//   2. Cascade soft-delete + batch restore via `delete_batch_id`. There is no
//      DB cascade — deletes are soft and performed in the service layer. When a
//      row is soft-deleted, it and its whole active subtree are stamped in one
//      transaction with the same `delete_batch_id`, so restoring the parent
//      restores exactly that batch (and nothing that was deleted separately
//      earlier). Parent FKs stay ON DELETE RESTRICT: we never hard-delete, and
//      RESTRICT guards against an accidental hard delete orphaning children.
//
// Audit columns `created_by`/`updated_by` are plain TEXT (String, NO @db.Uuid):
// they hold Better Auth user ids, which are opaque TEXT, not UUIDs — mirroring
// OrgMember.userId. Typing them as uuid breaks inserts (it bit the prior slice).
// ---------------------------------------------------------------------------

// Lifecycle state of a Plan — plain metadata in this slice (no scheduling maths
// keys off it yet). MUST stay in lock-step with the TypeScript `PlanStatus` union
// in @repo/types.
enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// The kind of schedule activity (PROJECT_BRIEF §8). All five are modelled so the
// deferred slices (dependencies, CPM, canvas) never need an enum migration; the
// web UI exposes only TASK + START/FINISH milestones in this slice — HAMMOCK and
// LEVEL_OF_EFFORT derive their duration from dependencies that don't exist yet.
enum ActivityType {
  TASK
  START_MILESTONE
  FINISH_MILESTONE
  HAMMOCK
  LEVEL_OF_EFFORT
}

// Progress state of an activity. Set via the progress path (Contributor+), never
// via the definition update.
enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

// Schedule constraint kinds (PROJECT_BRIEF §11). Reserved for the CPM engine
// (M6) — stored now so constraints round-trip before the engine honours them.
enum ConstraintType {
  SNET // start no earlier than
  SNLT // start no later than
  FNET // finish no earlier than
  FNLT // finish no later than
  MSO // must start on
  MFO // must finish on
  MANDATORY_START
  MANDATORY_FINISH
}

model Client {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  description    String?
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  // Correlation id (NOT a FK) shared by a row and every descendant soft-deleted
  // in the same operation; the unit of batch restore. Indexed by a partial index
  // (WHERE delete_batch_id IS NOT NULL) added as raw SQL in the migration.
  deleteBatchId  String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  projects     Project[]

  // Client name is unique per organisation among ACTIVE rows only — enforced by a
  // PARTIAL unique index (uq_clients_org_name ON (organization_id, name) WHERE
  // deleted_at IS NULL), added as raw SQL in the migration (Prisma cannot express
  // partial indexes). A soft-deleted name is therefore free to reuse.
  //
  // (organization_id, created_at, id) is a full composite that serves three
  // patterns at once: the organization_id FK (leftmost prefix), the org-scoped
  // active-list query, AND its deterministic cursor sort (ORDER BY created_at,
  // id). It subsumes a standalone organization_id index, so none is added.
  @@index([organizationId, createdAt, id])
  @@map("clients")
}

model Project {
  id             String    @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent client (see the block comment above). RESTRICT.
  organizationId String    @map("organization_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  name           String
  description    String?
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?   @map("created_by")
  updatedBy      String?   @map("updated_by")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId  String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  plans        Plan[]

  // Project name is unique per CLIENT among ACTIVE rows — partial unique
  // (uq_projects_client_name ON (client_id, name) WHERE deleted_at IS NULL), raw
  // SQL in the migration. The same name may exist under a different client.
  //
  // (client_id, created_at, id) covers the client FK (leftmost prefix), the
  // list-projects-under-a-client query and its cursor sort in one; it subsumes a
  // standalone client_id index. organization_id is indexed on its own to back its
  // FK (RESTRICT) and org-scoped IDOR loads; there is no org-wide ordered project
  // list, so a single column suffices (no composite needed there).
  @@index([clientId, createdAt, id])
  @@index([organizationId])
  @@map("projects")
}

model Plan {
  id             String     @id @default(uuid(7)) @db.Uuid
  // Denormalised from the parent project (see the block comment above). RESTRICT.
  organizationId String     @map("organization_id") @db.Uuid
  projectId      String     @map("project_id") @db.Uuid
  name           String
  description    String?
  status         PlanStatus @default(DRAFT)
  // Date-only (no time / no timezone): a plan's start is a calendar day, not an
  // instant, so it is @db.Date, not timestamptz. Optional metadata in this slice.
  plannedStart   DateTime?  @map("planned_start") @db.Date
  version        Int        @default(1)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy      String?    @map("created_by")
  updatedBy      String?    @map("updated_by")
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId  String?    @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Restrict)
  activities   Activity[]

  // Plan name is unique per PROJECT among ACTIVE rows — partial unique
  // (uq_plans_project_name ON (project_id, name) WHERE deleted_at IS NULL), raw
  // SQL in the migration.
  //
  // (project_id, created_at, id) covers the project FK, the list-plans-under-a-
  // project query and its cursor sort; subsumes a standalone project_id index.
  // organization_id is indexed on its own for its FK and org-scoped IDOR loads.
  @@index([projectId, createdAt, id])
  @@index([organizationId])
  @@map("plans")
}

// An Activity — the atomic unit of a schedule (PROJECT_BRIEF §9), the leaf of the
// Client → Project → Plan → Activity hierarchy. Org-scoped via a denormalised
// organization_id copied from the parent plan (never client input), following the
// Project/Plan pattern. The full field set is persisted now — including the
// CPM output columns and the graphical lane — so the deferred slices (M4
// dependencies, M5 calendars, M6 CPM engine, M7 TSLD canvas) are additive with no
// wide migration. The CPM columns are engine-owned: nullable/defaulted, never
// accepted from write DTOs, populated by the M6 engine.
model Activity {
  id             String @id @default(uuid(7)) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  planId         String @map("plan_id") @db.Uuid

  // Definition (Planner-owned).
  code           String?
  name           String
  description    String?
  type           ActivityType    @default(TASK)
  // Working days (= calendar days until the M5 Calendars slice); milestones are 0.
  durationDays   Int             @default(1) @map("duration_days")
  // Reserved for M5 (Calendars) — a nullable column with NO FK relation yet; not
  // client-settable in this slice.
  calendarId     String?         @map("calendar_id") @db.Uuid
  constraintType ConstraintType? @map("constraint_type")
  // Calendar day (date-only, no timezone), like Plan.plannedStart.
  constraintDate DateTime?       @map("constraint_date") @db.Date
  // Graphical y-lane / vertical offset for the TSLD canvas (M7); part of the
  // persisted model per PROJECT_BRIEF §9, not a runtime concern.
  laneIndex      Int             @default(0) @map("lane_index")

  // Progress (Contributor-updatable via the progress path).
  status          ActivityStatus @default(NOT_STARTED)
  percentComplete Int            @default(0) @map("percent_complete")
  actualStart     DateTime?      @map("actual_start") @db.Date
  actualFinish    DateTime?      @map("actual_finish") @db.Date

  // CPM output — engine-owned (M6). Nullable/defaulted; never set from input.
  earlyStart     DateTime? @map("early_start") @db.Date
  earlyFinish    DateTime? @map("early_finish") @db.Date
  lateStart      DateTime? @map("late_start") @db.Date
  lateFinish     DateTime? @map("late_finish") @db.Date
  totalFloat     Int?      @map("total_float")
  isCritical     Boolean   @default(false) @map("is_critical")
  isNearCritical Boolean   @default(false) @map("is_near_critical")

  // Housekeeping (as Project/Plan): TEXT audit ids (Better Auth ids are TEXT),
  // optimistic-lock version, soft delete + restore-batch correlation.
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy     String?   @map("created_by")
  updatedBy     String?   @map("updated_by")
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(3)
  deleteBatchId String?   @map("delete_batch_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Activity name (and, when present, code) are unique per PLAN among ACTIVE rows
  // — partial uniques (uq_activities_plan_name, uq_activities_plan_code WHERE
  // deleted_at IS NULL [AND code IS NOT NULL]), raw SQL in the migration.
  //
  // (plan_id, created_at, id) covers the plan FK, the list-activities-under-a-plan
  // query and its cursor sort in one. organization_id is indexed on its own for
  // its FK (RESTRICT) and org-scoped IDOR loads.
  @@index([planId, createdAt, id])
  @@index([organizationId])
  @@map("activities")
}
