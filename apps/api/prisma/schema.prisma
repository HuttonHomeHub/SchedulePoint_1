// Prisma schema for the Blank App API.
// Docs: https://www.prisma.io/docs
//
// Conventions: see docs/DATABASE.md. Columns are snake_case in the database
// (via @map/@@map) while Prisma fields stay camelCase. Timestamps are
// timestamptz (UTC). Primary keys are UUID v7 (time-ordered). Every table
// carries created_at/updated_at; mutable rows carry a soft-delete (deleted_at)
// and an optimistic-locking version.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity (Better Auth) — ADR-0003, ADR-0016.
//
// These four tables are owned by Better Auth (the authentication provider) and
// must keep the field names it expects; @map keeps the DB columns snake_case
// and the tables plural per docs/DATABASE.md. Their primary keys are the opaque
// string ids Better Auth generates (a deliberate, documented exception to the
// UUID-v7 default: these rows are library-managed, not domain rows). `User` is
// modelled here — not hidden inside the auth library — so future domain tables
// (OrgMember, Invitation, …) can foreign-key to it and be organisation-scoped.
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(3)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([identifier])
  @@map("verifications")
}
