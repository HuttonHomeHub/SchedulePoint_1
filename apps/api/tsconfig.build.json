{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    // `nest build` deletes dist on each run; incremental build info that lived
    // outside dist would make tsc skip re-emitting into the now-empty dist.
    // Disable incremental for the build so it always emits (turbo caches the
    // dist output anyway).
    "incremental": false
  },
  // The conformance harness (src/modules/schedule/conformance/) is a TEST asset:
  // it is imported only by *.spec.ts and depends on @repo/engine-conformance (a
  // devDependency vendored fixture), which is pruned from the production image.
  // `nest build` must not compile it — it is exercised by Vitest + `typecheck`
  // (tsconfig.json), never shipped. Same spirit as the *.spec.ts exclusion.
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "src/modules/schedule/conformance/**"
  ]
}
