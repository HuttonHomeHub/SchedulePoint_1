{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": [".env", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.*", "!**/*.spec.*"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
      "env": ["VITE_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "VITE_*",
        "DATABASE_URL",
        "API_PORT",
        "CORS_ORIGINS",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "POSTGRES_*"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": ["*.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "**/*.test.*", "**/*.spec.*"],
      "passThroughEnv": ["DATABASE_URL"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"],
      "passThroughEnv": ["PLAYWRIGHT_*", "E2E_*", "DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
