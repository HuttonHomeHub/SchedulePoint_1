# =============================================================================
# Blank App — environment variable template
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# For production, provide these via your secrets manager, not a file.
# See docs/DEPLOYMENT.md and SECURITY.md.
# -----------------------------------------------------------------------------

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# --- Database (PostgreSQL / Prisma) -----------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# Values used by docker-compose to provision the local Postgres container.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- API (NestJS) ------------------------------------------------------------
API_PORT=3000
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173
# Log level: fatal | error | warn | info | debug | trace | silent (default info).
LOG_LEVEL=info
# Rate limiting: window in seconds and max requests per window.
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# --- Authentication (Better Auth) -------------------------------------------
# Generate a strong random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-in-every-environment
BETTER_AUTH_URL=http://localhost:3000
# Require a verified email before an account is usable AND before an invitation
# can be accepted. Off for the alpha (the verification-email loop is not built
# yet); turning it on is the single switch that makes the invitation-accept
# email check a real proof of mailbox ownership (see ADR-0016, docs/TECH_DEBT.md).
AUTH_REQUIRE_EMAIL_VERIFICATION=false
# Comma-separated proxy IPs/CIDRs in front of the API (outermost→innermost).
# The auth rate limiter derives the client IP from X-Forwarded-For; listing the
# trusted proxies stops that header being spoofed to bypass the limit. REQUIRED
# in production (the app refuses to boot without it); leave empty in local dev.
TRUSTED_PROXY_IPS=

# --- Web (Vite) --------------------------------------------------------------
# Vite only exposes variables prefixed with VITE_ to the client bundle.
VITE_API_URL=http://localhost:3000
# On-canvas TSLD structural editing (M2). Off by default; set to "true" to enable
# create/move/link on the logic diagram. Stays flagged until the plan edit-lock
# lands (interim concurrency = optimistic-lock version-409 banner).
VITE_TSLD_EDITING=
