# =============================================================================
# Blank App — environment variable template
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit a real `.env`.
# For production, provide these via your secrets manager, not a file.
# See docs/DEPLOYMENT.md and SECURITY.md.
# -----------------------------------------------------------------------------

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# --- Database (PostgreSQL / Prisma) -----------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# Values used by docker-compose to provision the local Postgres container.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# --- API (NestJS) ------------------------------------------------------------
API_PORT=3000
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173
# Log level: fatal | error | warn | info | debug | trace | silent (default info).
LOG_LEVEL=info
# Rate limiting: window in seconds and max requests per window.
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# --- Authentication (Better Auth) -------------------------------------------
# Generate a strong random secret, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=change-me-in-every-environment
BETTER_AUTH_URL=http://localhost:3000
# Require a verified email before an account is usable AND before an invitation
# can be accepted. Off for the alpha (the verification-email loop is not built
# yet); turning it on is the single switch that makes the invitation-accept
# email check a real proof of mailbox ownership (see ADR-0016, docs/TECH_DEBT.md).
AUTH_REQUIRE_EMAIL_VERIFICATION=false
# Comma-separated proxy IPs/CIDRs in front of the API (outermost→innermost).
# The auth rate limiter derives the client IP from X-Forwarded-For; listing the
# trusted proxies stops that header being spoofed to bypass the limit. REQUIRED
# in production (the app refuses to boot without it); leave empty in local dev.
TRUSTED_PROXY_IPS=

# --- Plan edit-lock (ADR-0028) ----------------------------------------------
# When "true", structural plan writes (activity/dependency create/update/delete,
# positions batch, schedule recalculate) require the caller to hold the plan
# edit-lock and return 423 otherwise. Server-side enforcement is OFF by default
# and is the single deliberate rollout switch: the web pen (VITE_PLAN_EDIT_LOCK,
# below) now defaults ON, so users already acquire the pen on every editing entry
# point. Enable enforcement only AFTER a bundle with the pen on is deployed
# (ADR-0028 §9 ordering) — flipping it ahead of the web bundle would 423 those
# flows. The progress path and reads are never gated regardless of this flag.
PLAN_EDIT_LOCK_ENFORCED=false

# --- Web (Vite) --------------------------------------------------------------
# Vite only exposes variables prefixed with VITE_ to the client bundle.
VITE_API_URL=http://localhost:3000
# On-canvas TSLD structural editing (M2, ADR-0026). ON by default (2026-07-12) —
# create/move/link on the logic diagram is live. Set to "false" to fall back to
# the read-only M1 surface (rollback / opt-out). Leave blank to use the default.
VITE_TSLD_EDITING=
# Plan edit-lock "pen" web layer (ADR-0028). ON by default (2026-07-12): a Planner
# takes an exclusive lock ("Start editing") before the schedule-editing affordances
# go live, and peers see who holds it. Set to "false" to ship it inert (role-only
# gating, no lock polling). Keep this ON before enabling PLAN_EDIT_LOCK_ENFORCED.
VITE_PLAN_EDIT_LOCK=
# Canvas-first plan workspace (ADR-0030). ON by default (M5 gates green): opening a
# plan shows the TSLD canvas as the main workspace surface with the activity table as
# a draggable, collapsible bottom panel. Set to "false" to fall back to the legacy
# stacked plan-detail page (rollback / opt-out). Leave blank to use the default (on).
VITE_CANVAS_WORKSPACE=
# Canvas-maximal chrome reclaim + future-proof Toolbar architecture (ADR-0031), layered on
# the canvas-first workspace: slim header + one registry-driven toolbar row over a full-height
# canvas, secondary info in popovers/overflow. ON by default (2026-07-13, M5 gates green). Set to
# "false" to fall back to the ADR-0030 workspace (rollback / opt-out). Leave blank for the default (on).
VITE_CANVAS_TOOLBAR=
# Canvas-first plan authoring (ADR-0032), layered on the toolbar workspace: draw the first activity
# on a blank canvas, inline timeline start-date, auto-recalc after edits, on-canvas activity types
# (task + milestones), two-click Link tool. ON by default (M1–M5 shipped, gates green). Requires the
# toolbar + workspace flags (default-on); turning either off disables authoring too. Set to "false"
# to roll back to table-first authoring + edge-drag linking. Leave blank for the default (on).
VITE_CANVAS_AUTHORING=
# Scheduling modes & de-overloaded plan start (ADR-0033), layered on the canvas authoring host:
# plan-level Early/Visual scheduling mode + a read-only Late-Start overlay, a display-only "Go to
# date" control split out from the project start, and Visual Planning (dragging a bar records an
# advisory visualStart that pushes successors and flags conflicts). ON by default (M5 enablement).
# The mandatory project start (M1) is live independent of this flag. Requires the authoring host
# (default-on); turning it off disables scheduling modes too. Set to "false" to roll back to the
# single-mode canvas. Leave blank for the default (on).
VITE_SCHEDULING_MODES=
# Progress ingestion controls (ADR-0035, M2). Adds a remaining-duration input plus suspend/resume
# dates to the progress editor, and a plan-level recalc-mode picker (Retained Logic / Progress
# Override / Actual Dates). The engine ingests actuals and honours the plan's stored recalc mode
# regardless of this flag; the flag only governs whether a planner can edit the new fields in the
# web UI (percent + actual dates were always editable). ON by default — set to "false" to roll back
# to the percent-plus-actual-dates editor.
VITE_PROGRESS_INGESTION=
# Client-side undo/redo for plan authoring (ADR-0048). OFF by default — an in-progress feature
# shipping dark: it records inverse commands at the workspace-model seam with NO visible UI, and a
# later milestone adds the toolbar controls, keybindings and announcements before it flips on by
# default. When on, Undo/Redo replay plan INPUTS through the existing mutation hooks (behind the pen,
# never engine-owned derived columns) and the normal auto-recalc redraws. Set to "true" to opt in.
VITE_UNDO_REDO=

# --- Self-hosted RELEASE stack (docker-compose.release.yml) — NOT app config ---
# These are consumed only by the release stack on a self-hosted host, not by the
# app at runtime. See docs/DEPLOYMENT.md. Leave unset for the compose defaults.
#
# Image tag per app (each defaults to `latest`; the two version independently — ADR-0027).
# Pin a version to roll back or hold a known release; `latest` tracks the newest.
# WEB_IMAGE_TAG=latest                  # or a version like 0.31.0
# API_IMAGE_TAG=latest                  # or a version like 0.18.0
# IMAGE_TAG=latest                      # shared override for BOTH (e.g. a branch build: main / sha-<short>)
#
# Optional automatic redeploy via Watchtower (ADR-0047), enabled only when the
# `autodeploy` compose profile is active:
#   COMPOSE_PROFILES=autodeploy docker compose -f docker-compose.release.yml up -d
# WATCHTOWER_POLL_INTERVAL=300          # seconds between GHCR checks
# WATCHTOWER_MONITOR_ONLY=false         # true = notify only, don't auto-update (a manual gate)
# WATCHTOWER_NOTIFICATION_URL=          # optional shoutrrr URL for release notifications
# DOCKER_CONFIG_DIR=/root/.docker       # ABSOLUTE path to the dir holding the `docker login ghcr.io` config.json (no ~)
