          "original_duration_h": 40,
          "calendar": "CAL-01"
        }
      ],
      "relationships": [
        {
          "predecessor": "N2A",
          "successor": "N2A",
          "type": "FS",
          "lag_h": 0
        }
      ]
    },
    {
