{
  "name": "@repo/types",
  "version": "0.8.0",
  "private": true,
  "description": "Shared TypeScript types and DTO contracts between the web and api workspaces.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "eslint": "^9.39.5",
    "typescript": "catalog:"
  }
}
