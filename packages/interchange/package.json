{
  "name": "@repo/interchange",
  "version": "0.0.0",
  "private": true,
  "description": "Pure, engine-free schedule-interchange substrate: the format-agnostic canonical model, per-format parsers, the SchedulePoint mapper, and the ADR-0035 validate/repair/report contract (ADR-0050).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
