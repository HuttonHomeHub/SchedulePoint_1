{
  // Extended via a direct relative path (not the "@repo/config" package name): Vitest's Oxc
  // transformer can't resolve a tsconfig `extends` through pnpm's node_modules symlink, so the
  // package-name form breaks the test run. tsc resolves either form (mirrors packages/engine-conformance).
  "extends": "../config/tsconfig/base.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": true,
    "composite": false
  },
  "include": ["src/**/*.ts"]
}
